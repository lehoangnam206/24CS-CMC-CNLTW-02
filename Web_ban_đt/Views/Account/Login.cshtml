@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - TechStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
            body {
                background-color: #4285F4;
                display: flex;
                align-items: center;
                justify-content: center;
                height: 100vh;
                margin: 0;
            }

            .auth-card {
                background: white;
                border-radius: 20px;
                overflow: hidden;
                max-width: 850px;
                width: 100%;
                box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            }

            .bg-img {
                background: linear-gradient(135deg, #0b3d91, #1a56db);
                padding: 40px;
                color: white;
                text-align: center;
            }

            .form-control {
                background-color: #e9ecef;
                border: none;
                border-radius: 8px;
                padding: 10px 10px 10px 45px;
            }

            .input-group-custom {
                position: relative;
            }

            .input-icon {
                position: absolute;
                left: 15px;
                top: 50%;
                transform: translateY(-50%);
                color: #555;
                z-index: 10;
            }

            .btn-login {
                background-color: #4285F4;
                color: white;
                border: none;
                padding: 10px;
                font-weight: 500;
            }

                .btn-login:hover {
                    background-color: #2a6edb;
                    color: white;
                }

            .btn-create-acc {
                background-color: #e9ecef;
                color: #333;
                border: none;
                padding: 10px;
                font-weight: 500;
            }

                .btn-create-acc:hover {
                    background-color: #dcdfe1;
                    color: #111;
                }
    </style>
</head>
<body>
    <div class="auth-card d-flex row m-2">
        <div class="col-md-6 bg-img d-flex flex-column justify-content-center align-items-center p-5 text-center">
            <div class="mb-4">
                <i class="bi bi-cpu text-white" style="font-size: 80px;"></i>
            </div>
            <h2 class="fw-bold">TECHSTORE</h2>
            <p class="small text-white-50">EXPLORE THE INNOVATION - SIGN IN TO YOUR ACCOUNT</p>
        </div>

        <div class="col-md-6 p-5 bg-white d-flex flex-column justify-content-center">
            <h3 class="text-center fw-bold mb-4" style="color: #333;">Đăng Nhập</h3>

            <form action="/Home/Index" method="get">
                <div class="input-group-custom mb-3">
                    <i class="bi bi-person-fill input-icon"></i>
                    <input type="text" class="form-control" placeholder="Tên đăng nhập" required>
                </div>

                <div class="input-group-custom mb-2">
                    <i class="bi bi-lock-fill input-icon"></i>
                    <input type="password" class="form-control" placeholder="Mật Khẩu" required>
                </div>

                <div class="text-end mb-4">
                    <a href="#" class="text-muted small text-decoration-none">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="btn btn-login w-100 rounded-pill mb-3">Đăng Nhập</button>

                <a href="/Account/Register" class="btn btn-create-acc w-100 rounded-pill text-decoration-none text-center d-block">Tạo tài khoản mới</a>
            </form>
        </div>
    </div>
</body>
</html>