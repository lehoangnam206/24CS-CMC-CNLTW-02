@model TechStoreWeb.Models.Promotion

@{
    ViewData["Title"] = "Thêm chương trình khuyến mại";
    var products = ViewBag.Products as IEnumerable<TechStoreWeb.Models.Product>;
}

<div class="mb-4 d-flex align-items-center">
    <a href="/Admin/Promotions" class="text-decoration-none text-muted me-3 fs-5"><i class="bi bi-arrow-left"></i></a>
    <h2 class="mb-0">@ViewData["Title"]</h2>
</div>

<form method="post" action="/Admin/Promotions/Create">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-3">Thông tin chung</h5>
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Tên chương trình</label>
                        <input asp-for="Name" class="form-control" placeholder="Ví dụ: Mừng Tết đến" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label fw-semibold">Từ ngày</label>
                            <input asp-for="StartDate" type="datetime-local" class="form-control" required />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-semibold">Đến ngày</label>
                            <input asp-for="EndDate" type="datetime-local" class="form-control" required />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveSwitch" checked>
                        <label class="form-check-label fw-semibold" for="isActiveSwitch">Kích hoạt chương trình</label>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-3">Hình thức khuyến mại</h5>
                    
                    <div class="mb-3">
                        <label asp-for="DiscountPercentage" class="form-label fw-semibold">Giảm giá theo %</label>
                        <div class="input-group">
                            <input asp-for="DiscountPercentage" type="number" class="form-control" placeholder="Nhập phần trăm giảm (1-100)" min="1" max="100" required />
                            <span class="input-group-text bg-light">%</span>
                        </div>
                        <span asp-validation-for="DiscountPercentage" class="text-danger"></span>
                    </div>

                    <hr />

                    <h6 class="fw-bold mb-3">Áp dụng cho sản phẩm</h6>
                    <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                        <table class="table table-bordered table-hover mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th style="width: 50px;" class="text-center">
                                        <input class="form-check-input" type="checkbox" id="selectAllProducts">
                                    </th>
                                    <th>Sản phẩm</th>
                                    <th>Giá hiện tại</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (products != null)
                                {
                                    foreach (var p in products)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <input class="form-check-input product-checkbox" type="checkbox" name="productIds" value="@p.ProductId">
                                            </td>
                                            <td>@p.Name</td>
                                            <td>@p.Price.ToString("N0") VNĐ</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <small class="text-muted mt-2 d-block"><i class="bi bi-info-circle"></i> Giá trị của sản phẩm sẽ được tự động cập nhật sau khi bạn Lưu.</small>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Hoàn tất</h5>
                    <p class="text-muted small">Kiểm tra kỹ thông tin trước khi lưu. Thay đổi giá sẽ áp dụng ngay lập tức cho các sản phẩm được chọn.</p>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary bg-techblue border-0 py-2 fw-bold">
                            <i class="bi bi-save me-1"></i> Lưu khuyến mại
                        </button>
                        <a href="/Admin/Promotions" class="btn btn-outline-secondary py-2">
                            Bỏ qua
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        document.getElementById('selectAllProducts').addEventListener('change', function() {
            var checkboxes = document.querySelectorAll('.product-checkbox');
            for (var checkbox of checkboxes) {
                checkbox.checked = this.checked;
            }
        });
    </script>
}
