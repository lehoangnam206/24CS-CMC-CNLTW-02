@model TechStoreWeb.Models.Order
@{
    ViewData["Title"] = "Chi tiết Đơn hàng #" + Model.OrderId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0 text-techblue">Chi tiết Đơn hàng #@Model.OrderId</h3>
    <a href="/Admin/Orders" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white fw-bold py-3">
                <i class="bi bi-box-seam text-primary me-2"></i> Sản phẩm trong đơn hàng
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Sản phẩm</th>
                                <th class="text-center">Đơn giá</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end pe-4">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in Model.OrderDetails)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <img src="@detail.Product.ImageUrl" alt="@detail.Product.Name" style="width: 50px; height: 50px; object-fit: contain;" class="me-3 border rounded p-1" />
                                            <div>
                                                <h6 class="mb-0">@detail.Product.Name</h6>
                                                <small class="text-muted">Mã SP: @detail.ProductId</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">@detail.UnitPrice.ToString("N0") VNĐ</td>
                                    <td class="text-center">@detail.Quantity</td>
                                    <td class="text-end pe-4 fw-bold">@((detail.Quantity * detail.UnitPrice).ToString("N0")) VNĐ</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Tổng tiền đơn hàng:</td>
                                <td class="text-end pe-4 fw-bold text-danger fs-5">@Model.TotalAmount.ToString("N0") VNĐ</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white fw-bold py-3">
                <i class="bi bi-person text-primary me-2"></i> Thông tin Khách hàng
            </div>
            <div class="card-body">
                <p class="mb-2"><strong>Họ tên:</strong> @Model.User?.FullName</p>
                <p class="mb-2"><strong>Số điện thoại:</strong> @Model.User?.PhoneNumber</p>
                <p class="mb-2"><strong>Email:</strong> @Model.User?.Email</p>
                <hr />
                <p class="mb-2"><strong>Địa chỉ giao hàng:</strong><br />@Model.ShippingAddress</p>
                <p class="mb-0"><strong>Phương thức thanh toán:</strong> @Model.PaymentMethod</p>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-bold py-3">
                <i class="bi bi-arrow-repeat text-primary me-2"></i> Cập nhật Trạng thái
            </div>
            <div class="card-body">
                <form action="/Admin/Orders/UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    
                    <div class="mb-3">
                        <label class="form-label">Trạng thái hiện tại:</label>
                        <select name="status" class="form-select">
                            <option value="Pending" selected="@(Model.Status == "Pending")">Chờ xử lý</option>
                            <option value="WaitingForPickup" selected="@(Model.Status == "WaitingForPickup")">Chờ lấy hàng</option>
                            <option value="PickedUp" selected="@(Model.Status == "PickedUp")">Đã lấy hàng</option>
                            <option value="Shipping" selected="@(Model.Status == "Shipping")">Đang vận chuyển</option>
                            <option value="Delivered" selected="@(Model.Status == "Delivered")">Đã giao</option>
                            <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Đã hủy</option>
                        </select>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">Cập nhật Trạng thái</button>
                </form>
            </div>
        </div>
    </div>
</div>
