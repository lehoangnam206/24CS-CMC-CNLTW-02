                        <div class="banner-tab-title">ĐIỆN THOẠI MỚI</div>
                        <div class="banner-tab-desc">Mở bán giá tốt</div>
                    </div>
                    <div class="banner-tab-item" onclick="setSlide(2)">
                        <div class="banner-tab-title">GALAXY S26 ULTRA</div>
