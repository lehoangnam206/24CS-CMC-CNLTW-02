@{
    ViewData["Title"] = "Đăng nhập";
}

@section Styles {
    <style>
        .auth-wrapper {
            background-color: var(--bg-color);
            min-height: calc(100vh - 72px);
            width: 100vw;
            position: relative;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            margin: 0;
        }
        
        .auth-card {
            display: flex;
            background: var(--surface-color);
            border-radius: var(--radius-xl);
            padding: 8px;
            box-shadow: var(--shadow-float);
            width: 100%;
            max-width: 1000px;
            min-height: 600px;
            border: 1px solid rgba(0,0,0,0.03);
        }
        
        .auth-left {
            flex: 1.2;
            background: url('/images/Giao diện trang chủ/Đăng nhập.png') center/cover no-repeat;
            border-radius: calc(var(--radius-xl) - 8px);
            position: relative;
            overflow: hidden;
            box-shadow: inset 0 0 0 1px rgba(255,255,255,0.2);
        }
        
        .auth-right {
            flex: 1;
            padding: 64px 48px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background-color: var(--surface-color);
        }
        
        .auth-title {
            font-size: 36px;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 12px;
            letter-spacing: -0.04em;
        }

        .auth-subtitle {
            color: var(--text-muted);
            font-size: 15px;
            margin-bottom: 40px;
            font-weight: 500;
        }
        
        .input-group-custom {
            display: flex;
            align-items: center;
            background-color: var(--bg-color);
            border: 1px solid rgba(0,0,0,0.05);
            border-radius: var(--radius-lg);
            padding: 4px 24px;
            margin-bottom: 24px;
            transition: all 0.3s var(--bezier-smooth);
        }
        
        .input-group-custom:focus-within {
            background-color: var(--surface-color);
            border-color: var(--primary-color);
            box-shadow: 0 4px 16px rgba(37, 99, 235, 0.1);
            transform: translateY(-2px);
        }

        .input-group-custom i {
            font-size: 20px;
            color: rgba(0,0,0,0.2);
            margin-right: 16px;
            transition: color 0.3s;
        }

        .input-group-custom:focus-within i { color: var(--primary-color); }
        
        .form-control-custom {
            flex: 1;
            border: none;
            background: transparent;
            padding: 16px 0;
            font-size: 16px;
            font-weight: 500;
            color: var(--text-main);
            outline: none;
            font-family: inherit;
        }
        
        .form-control-custom::placeholder { color: var(--text-muted); font-weight: 400; }
        
        .forgot-password {
            text-align: right;
            display: block;
            font-size: 14px;
            color: var(--text-muted);
            margin-top: -12px;
            margin-bottom: 32px;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s;
        }
        
        .forgot-password:hover { color: var(--primary-color); }
        
        .btn-login {
            background: var(--primary-color);
            color: var(--surface-color);
            border: none;
            border-radius: var(--radius-pill);
            padding: 20px;
            width: 100%;
            font-weight: 700;
            font-size: 16px;
            transition: all 0.4s var(--bezier-smooth);
            margin-bottom: 16px;
            cursor: pointer;
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
            font-family: inherit;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }
        
        .btn-login:hover {
            transform: translateY(-4px) scale(0.98);
            box-shadow: 0 16px 32px rgba(0,0,0,0.2);
            background: var(--primary-color);
        }

        /* Social Login Divider & Buttons */
        .social-divider {
            display: flex;
            align-items: center;
            text-align: center;
            color: var(--text-muted);
            font-size: 13px;
            margin: 28px 0 24px 0;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        .social-divider::before, .social-divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }
        
        .social-divider span { padding: 0 16px; }

        .social-buttons {
            display: flex;
            gap: 16px;
            margin-bottom: 16px;
        }

        .btn-social {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 16px 20px;
            border-radius: var(--radius-pill);
            font-size: 14px;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.4s var(--bezier-smooth);
            text-decoration: none;
            border: none;
        }

        .btn-social i { font-size: 20px; }

        .btn-social-facebook {
            background: #1877f2;
            color: #ffffff;
            box-shadow: 0 4px 14px rgba(24, 119, 242, 0.3);
        }

        .btn-social-facebook:hover {
            background: #1565c0;
            transform: translateY(-4px) scale(0.98);
            box-shadow: 0 10px 24px rgba(24, 119, 242, 0.4);
            color: #ffffff;
        }

        .btn-social-google {
            background: #ffffff;
            color: var(--text-main);
            border: 2px solid rgba(0,0,0,0.08);
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

        .btn-social-google:hover {
            border-color: #ea4335;
            transform: translateY(-4px) scale(0.98);
            box-shadow: 0 10px 24px rgba(234, 67, 53, 0.15);
            color: var(--text-main);
        }

        .btn-social-google .google-icon {
            width: 20px;
            height: 20px;
        }

        .btn-register {
            background-color: transparent;
            color: var(--text-main);
            border: 2px solid rgba(0,0,0,0.05);
            border-radius: var(--radius-pill);
            padding: 18px;
            width: 100%;
            font-weight: 700;
            font-size: 16px;
            transition: all 0.3s var(--bezier-smooth);
            text-align: center;
            display: inline-block;
            text-decoration: none;
            cursor: pointer;
            font-family: inherit;
        }
        
        .btn-register:hover {
            background-color: rgba(0,0,0,0.02);
            border-color: rgba(0,0,0,0.1);
        }
        
        @@media (max-width: 768px) {
            .auth-card { flex-direction: column; }
            .auth-left { min-height: 250px; border-radius: calc(var(--radius-xl) - 8px) calc(var(--radius-xl) - 8px) 0 0; }
            .auth-right { padding: 40px 24px; }
            .social-buttons { flex-direction: column; }
        }
        footer { display: none !important; }
    </style>
}

<div class="auth-wrapper">
    <div class="auth-card">
        <!-- Left Side: Image/Branding -->
        <div class="auth-left"></div>

        <!-- Right Side: Form -->
        <div class="auth-right">
            <h3 class="auth-title">Đăng Nhập</h3>
            <p class="auth-subtitle">Vui lòng nhập thông tin để tiếp tục</p>
            
            @if (TempData["SuccessMessage"] != null)
            {
                <div style="background: rgba(16, 185, 129, 0.1); color: #10b981; border-radius: var(--radius-lg); padding: 16px 24px; font-weight: 600; font-size: 14px; display: flex; align-items: center; gap: 12px; margin-bottom: 32px;">
                    <i class="bi bi-check2-circle" style="font-size: 20px;"></i>
                    @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border-radius: var(--radius-lg); padding: 16px 24px; font-weight: 600; font-size: 14px; display: flex; align-items: center; gap: 12px; margin-bottom: 32px;">
                    <i class="bi bi-exclamation-circle" style="font-size: 20px;"></i>
                    @TempData["ErrorMessage"]
                </div>
            }

            <!-- Form đăng nhập thường -->
            <form asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <div asp-validation-summary="ModelOnly" style="font-size: 14px; padding: 16px 24px; background: rgba(239, 68, 68, 0.1); color: #ef4444; border-radius: var(--radius-lg); margin-bottom: 24px; font-weight: 500;"></div>

                <div class="input-group-custom">
                    <i class="bi bi-envelope"></i>
                    <input type="text" name="username" class="form-control-custom" placeholder="Email hoặc tên đăng nhập" required />
                </div>

                <div class="input-group-custom">
                    <i class="bi bi-lock"></i>
                    <input type="password" name="password" class="form-control-custom" placeholder="Mật khẩu" required />
                </div>

                <a href="#" class="forgot-password">Quên mật khẩu?</a>

                <button type="submit" class="btn-login">Đăng nhập <i class="bi bi-arrow-right"></i></button>
            </form>

            <!-- Divider -->
            <div class="social-divider">
                <span>Hoặc đăng nhập bằng</span>
            </div>

            <!-- Nút Facebook & Google -->
            <div class="social-buttons">
                <a href="/Account/ExternalLogin?provider=Facebook&returnUrl=@(ViewData["ReturnUrl"] ?? "/")" class="btn-social btn-social-facebook">
                    <i class="bi bi-facebook"></i> Facebook
                </a>
                <a href="/Account/ExternalLogin?provider=Google&returnUrl=@(ViewData["ReturnUrl"] ?? "/")" class="btn-social btn-social-google">
                    <svg class="google-icon" viewBox="0 0 24 24">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    Google
                </a>
            </div>

            <a href="/Account/Register?returnUrl=@ViewData["ReturnUrl"]" class="btn-register">Tạo tài khoản mới</a>
        </div>
    </div>
</div>