    }
    else
    {
        var searchStr = Context.Request.Query["searchString"];
        var catId = Context.Request.Query["categoryId"];
        
        <div class="breadcrumb-nav">
            <a href="/">Trang chủ</a>
            <span class="separator">/</span>
            @if (!string.IsNullOrEmpty(searchStr))
            {
                <span class="current">Tìm kiếm</span>
            }
            else
            {
                var catName = categories?.FirstOrDefault(c => c.CategoryId.ToString() == catId)?.CategoryName ?? "Sản phẩm";
                <span class="current">@catName</span>
            }
        </div>

        <div class="section-header">
            <h3>
                @if (!string.IsNullOrEmpty(searchStr))
                {
                    <text>TÌM KIẾM: <span style="color: var(--primary-color);">"@searchStr"</span></text>
                }
                else
                {
                    var catName = categories?.FirstOrDefault(c => c.CategoryId.ToString() == catId)?.CategoryName ?? "SẢN PHẨM";
                    <text>DANH MỤC: <span style="color: var(--primary-color);">@catName.ToUpper()</span></text>
                }
            </h3>
        </div>
    }

    <!-- Product List -->
    <div class="product-list">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="product-card">
                    <a href="/Home/Detail/@item.ProductId" style="display:block; text-decoration: none;">
                        <img src="@item.ImageUrl" alt="@item.Name">
                        <div class="product-name">@item.Name</div>
                        <div class="price-row">
                            <div class="product-price">@item.Price.ToString("N0")đ</div>
                            <div class="product-old-price">@((item.Price * 1.2m).ToString("N0"))đ</div>
                        </div>
                        <div class="promo-box">
                            <p>Không phí chuyển đổi khi trả góp qua thẻ tín dụng</p>
                        </div>
                        <div class="rating-row">
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-half"></i>
                            <span>(12 đánh giá)</span>
                        </div>
                    </a>

                    <form asp-controller="Cart" asp-action="Add" method="post" style="width: 100%;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@item.ProductId" />
                        <button type="submit" class="add-to-cart-btn">
                            <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                        </button>
                    </form>
                </div>
            }
        }
        else
        {
            <div style="grid-column: 1 / -1; text-align: center; padding: 80px 0;">
                <i class="bi bi-box" style="font-size: 48px; color: var(--text-muted); opacity: 0.3;"></i>
                <p style="margin-top: 16px; color: var(--text-muted);">Không tìm thấy sản phẩm nào.</p>
            </div>
        }
    </div>

    @{
        var currentPage = ViewBag.CurrentPage as int? ?? 1;
        var totalPages = ViewBag.TotalPages as int? ?? 1;
        var totalItems = ViewBag.TotalItems as int? ?? 0;
        var qCategoryId = Context.Request.Query["categoryId"].ToString();
        var qSearch = Context.Request.Query["searchString"].ToString();

        Func<int, string> pageUrl = p =>
        {
            var parts = new List<string>();
            if (!string.IsNullOrEmpty(qCategoryId)) parts.Add($"categoryId={Uri.EscapeDataString(qCategoryId)}");
            if (!string.IsNullOrEmpty(qSearch)) parts.Add($"searchString={Uri.EscapeDataString(qSearch)}");
            parts.Add($"page={p}");
            return "/Home/Index?" + string.Join("&", parts);
        };
    }

    @if (totalPages > 1)
    {
        var windowStart = Math.Max(1, currentPage - 2);
        var windowEnd = Math.Min(totalPages, windowStart + 4);
        windowStart = Math.Max(1, windowEnd - 4);

        <nav class="pagination-bar" aria-label="Phân trang sản phẩm">
            <div class="pagination-info">
                Hiển thị trang <strong>@currentPage</strong> / @totalPages — tổng @totalItems sản phẩm
            </div>
            <ul class="pagination-list">
                <li>
                    <a class="page-link @(currentPage <= 1 ? "disabled" : "")"
                       href="@(currentPage <= 1 ? "#" : pageUrl(currentPage - 1))"
                       aria-label="Trang trước">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>

                @if (windowStart > 1)
                {
                    <li><a class="page-link" href="@pageUrl(1)">1</a></li>
                    @if (windowStart > 2)
                    {
                        <li><span class="page-ellipsis">…</span></li>
                    }
                }

                @for (var p = windowStart; p <= windowEnd; p++)
                {
                    <li><a class="page-link @(p == currentPage ? "active" : "")" href="@pageUrl(p)">@p</a></li>
                }

                @if (windowEnd < totalPages)
                {
                    @if (windowEnd < totalPages - 1)
                    {
                        <li><span class="page-ellipsis">…</span></li>
                    }
                    <li><a class="page-link" href="@pageUrl(totalPages)">@totalPages</a></li>
                }

                <li>
                    <a class="page-link @(currentPage >= totalPages ? "disabled" : "")"
                       href="@(currentPage >= totalPages ? "#" : pageUrl(currentPage + 1))"
                       aria-label="Trang sau">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        let currentSlide = 0;
        const slides = document.querySelectorAll('.slide-item');
        const tabs = document.querySelectorAll('.banner-tab-item');
        let slideInterval;

        function showSlide(index) {
            if (index >= slides.length) currentSlide = 0;
            else if (index < 0) currentSlide = slides.length - 1;
            else currentSlide = index;

            slides.forEach(s => s.classList.remove('active'));
            tabs.forEach(t => t.classList.remove('active'));

            slides[currentSlide].classList.add('active');
            tabs[currentSlide].classList.add('active');
        }

        function moveSlide(step) {
            showSlide(currentSlide + step);
            resetInterval();
        }

        function setSlide(index) {
            showSlide(index);
            resetInterval();
        }

        function resetInterval() {
            clearInterval(slideInterval);
            slideInterval = setInterval(() => {
                moveSlide(1);
            }, 6000); 
        }

        resetInterval();
    </script>
}
