@model TechStoreWeb.Models.Product
@{
    ViewData["Title"] = "Thêm Sản phẩm";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card shadow-sm border-0" style="border-radius: 16px; overflow: hidden;">
            <div class="card-header border-0 py-4" style="background: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%); color: white;">
                <h4 class="mb-0 fw-bold"><i class="bi bi-box-seam me-2"></i>Thêm Sản phẩm mới</h4>
                <p class="mb-0 text-white-50 small mt-1">Nhập thông tin chi tiết cho sản phẩm mới vào form dưới đây</p>
            </div>
            <div class="card-body p-5">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4 p-3 bg-danger bg-opacity-10 rounded"></div>
                    
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-semibold text-muted">Tên sản phẩm</label>
                            <input asp-for="Name" class="form-control form-control-lg bg-light border-0" placeholder="VD: iPhone 15 Pro Max" required style="border-radius: 10px;" />
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label fw-semibold text-muted">Danh mục</label>
                            <select asp-for="CategoryId" class="form-select form-select-lg bg-light border-0" asp-items="ViewBag.CategoryId" style="border-radius: 10px;"></select>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label fw-semibold text-muted">Giá (VNĐ)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 text-muted" style="border-top-left-radius: 10px; border-bottom-left-radius: 10px;">₫</span>
                                <input asp-for="Price" type="number" step="1000" class="form-control form-control-lg bg-light border-0" placeholder="VD: 29990000" required style="border-top-right-radius: 10px; border-bottom-right-radius: 10px;" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ImageUrl" class="form-label fw-semibold text-muted">URL Hình ảnh</label>
                            <input asp-for="ImageUrl" class="form-control form-control-lg bg-light border-0" placeholder="/images/abc.jpg" required style="border-radius: 10px;" />
                            <span asp-validation-for="ImageUrl" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <hr class="my-5 border-light" />

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn text-white px-5 py-3 shadow-sm" style="background: linear-gradient(135deg, #06d6a0 0%, #118ab2 100%); border-radius: 12px; font-weight: 600; font-size: 16px; transition: transform 0.2s;">
                            <i class="bi bi-save-fill me-2"></i> Lưu sản phẩm
                        </button>
                        <a asp-action="Index" class="btn btn-light px-5 py-3 text-muted fw-medium" style="border-radius: 12px; background: #f1f5f9;">
                            <i class="bi bi-x-circle me-2"></i> Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus, .form-select:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 4px rgba(67, 97, 238, 0.1) !important;
    }
    button[type="submit"]:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(17, 138, 178, 0.3) !important;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
