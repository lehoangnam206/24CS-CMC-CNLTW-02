@inject TechStoreWeb.Data.AppDbContext _layoutContext
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechStore</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        /* 1. Global Styles & Premium Variables */
        :root {
            --primary-color: #2563eb;
            --primary-hover: #1d4ed8;
            --bg-color: #fcfcfd;
            --surface-color: #ffffff;
            --text-main: #0a0a0a;
            --text-muted: #737373;
            
            --bezier-smooth: cubic-bezier(0.32, 0.72, 0, 1);
            --bezier-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
            --transition-speed: 0.5s;

            /* Haptic shadows & Structural depths */
            --shadow-float: 0 24px 48px -12px rgba(0, 0, 0, 0.08);
            --shadow-soft: 0 8px 30px rgba(0, 0, 0, 0.04);
            --shadow-inner: inset 0 1px 1px rgba(255, 255, 255, 0.8);
            
            --radius-md: 16px;
            --radius-lg: 24px;
            --radius-xl: 32px;
            --radius-pill: 9999px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            text-decoration: none;
            list-style: none;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            font-size: 15px;
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            letter-spacing: -0.01em;
            line-height: 1.6;
        }

        input:-webkit-autofill,
        input:-webkit-autofill:hover, 
        input:-webkit-autofill:focus, 
        input:-webkit-autofill:active {
            transition: background-color 50000s ease-in-out 0s;
            -webkit-text-fill-color: var(--text-main) !important;
        }

        .container {
            width: 100%;
            max-width: 1920px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* 2. Classic E-commerce Header */
        .site-header {
            background-color: var(--primary-color);
            background: linear-gradient(90deg, #2563eb, #1d4ed8);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            width: 100%;
        }

        .site-header .container {
            display: flex;
            align-items: center;
            height: 64px;
            gap: 16px;
        }

        .header-logo {
            font-size: 22px;
            font-weight: 800;
            letter-spacing: -0.04em;
            color: #ffffff;
            text-decoration: none;
            display: flex;
            align-items: center;
            flex-shrink: 0;
        }
        .header-logo:hover { color: #ffffff; opacity: 0.9; }

        .search-bar-container {
            display: flex;
            flex: 1;
            border-radius: 8px;
            background-color: #ffffff;
            height: 38px;
            position: relative;
            align-items: center;
            overflow: hidden;
            margin: 0 16px;
        }
        .search-bar-container input {
            flex: 1;
            border: none;
            padding: 0 8px;
            outline: none;
            font-size: 13px;
            color: var(--text-main);
            background: transparent;
        }
        .search-bar-container button {
            background: transparent;
            border: none;
            padding: 0 12px;
            cursor: pointer;
            color: #777;
            font-size: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .header-actions {
            display: flex;
            gap: 12px;
            align-items: center;
            flex-shrink: 0;
        }

        .action-btn {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 8px;
            padding: 8px 12px;
            display: flex;
            align-items: center;
            gap: 8px;
            color: white;
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            transition: 0.2s;
            position: relative;
        }
        .action-btn:hover {
            background: rgba(255, 255, 255, 0.25);
            color: white;
        }
        .action-btn i {
            font-size: 16px;
            color: white;
        }

        .cart-badge {
            background: #f97316;
            color: white;
            border-radius: var(--radius-pill);
            padding: 0 4px;
            font-size: 10px;
            font-weight: 700;
            position: absolute;
            top: -6px;
            right: -6px;
            height: 16px;
            min-width: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 2px solid var(--primary-color);
        }

        /* Header Category Menu */
        .header-menu-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            flex-shrink: 0;
        }
        .header-menu-btn {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 8px;
            padding: 8px 12px;
            display: flex;
            align-items: center;
            gap: 6px;
            color: white;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            transition: 0.2s;
        }
        .header-menu-btn:hover { background: rgba(255, 255, 255, 0.25); }
        .header-menu-dropdown {
            position: absolute;
            top: 100%;
            left: 0;
            width: 260px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.15);
            opacity: 0;
            visibility: hidden;
            transition: all 0.2s var(--bezier-smooth);
            z-index: 1001;
            margin-top: 16px;
            padding: 8px 0;
        }
        .header-menu-wrapper:hover .header-menu-dropdown {
            opacity: 1;
            visibility: visible;
            margin-top: 8px;
        }
        .header-menu-dropdown ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; }
        .header-menu-dropdown li a {
            display: flex;
            align-items: center;
            padding: 10px 16px;
            color: var(--text-main);
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: 0.2s;
        }
        .header-menu-dropdown li a:hover {
            background: rgba(37, 99, 235, 0.05);
            color: var(--primary-color);
        }
        .header-menu-dropdown li a i:first-child {
            font-size: 16px;
            margin-right: 12px;
            width: 20px;
            text-align: center;
            color: var(--text-muted);
        }
        .header-menu-dropdown li a:hover i:first-child {
            color: var(--primary-color);
        }
        .header-menu-dropdown li a i.bi-chevron-right {
            margin-left: auto;
            font-size: 11px;
            color: var(--text-muted);
        }

        /* 3. Main Layout Grid */
        .main-layout {
            padding: 24px 0 100px 0;
        }

        footer {
            text-align: center;
            padding: 60px 24px;
            color: var(--text-muted);
            font-size: 14px;
            margin-top: 40px;
        }

        @@media (max-width: 1024px) {
            .site-header .container { gap: 16px; padding: 0 16px; }
            .search-bar-container { display: none; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="site-header">
        <div class="container">
            <a href="/" class="header-logo" aria-label="Home">
                TECHBLUE
            </a>

            <div class="header-menu-wrapper">
                <div class="header-menu-btn">
                    <i class="bi bi-grid-fill"></i>
                    <span>Danh mục</span>
                    <i class="bi bi-chevron-down" style="font-size: 10px; margin-left: 2px;"></i>
                </div>
                <div class="header-menu-dropdown">
                    <ul>
                        @{
                            var layoutCategories = _layoutContext.Categories.ToList();
                            if (layoutCategories.Any())
                            {
                                foreach (var cat in layoutCategories)
                                {
                                    <li><a href="/Home/Index?categoryId=@cat.CategoryId"><i class="bi bi-phone"></i> @cat.CategoryName <i class="bi bi-chevron-right"></i></a></li>
                                }
                            }
                            else
                            {
                                <li><a href="#"><i class="bi bi-phone"></i> Đang cập nhật... <i class="bi bi-chevron-right"></i></a></li>
                            }
                        }
                    </ul>
                </div>
            </div>

            <form action="/Home/Index" method="get" class="search-bar-container">
                <button type="submit" aria-label="Tìm kiếm"><i class="bi bi-search"></i></button>
                <input type="text" name="searchString" placeholder="Bạn muốn mua gì hôm nay?" value="@((string)ViewData["SearchString"] ?? Context.Request.Query["searchString"])" />
            </form>

            <div class="header-actions">
                <a href="/Cart/Index" class="action-btn">
                    <i class="bi bi-bag"></i>
                    <span>Giỏ hàng</span>
                    @{ 
                        var _cart = Context.Session.GetString("Cart");
                        int _qty = 0;
                        if (!string.IsNullOrEmpty(_cart))
                        {
                            try {
                                var _list = System.Text.Json.JsonSerializer.Deserialize<List<TechStoreWeb.Models.CartItem>>(_cart);
                                if (_list != null) _qty = _list.Sum(i=>i.Qty);
                            } catch {}
                        }
                    }
                    <span class="cart-badge">@_qty</span>
                </a>
                @{
                    var username = Context.Session.GetString("Username");
                    var role = Context.Session.GetString("Role");
                }
                @if (string.IsNullOrEmpty(username))
                {
                    var currentUrl = Context.Request.Path + Context.Request.QueryString;
                    <a href="/Account/Login?returnUrl=@System.Net.WebUtility.UrlEncode(currentUrl)" class="action-btn">
                        <i class="bi bi-person-circle"></i>
                        <span>Đăng nhập</span>
                    </a>
                }
                else
                {
                    <a href="/Account/Profile" class="action-btn">
                        <i class="bi bi-person-circle"></i>
                        <span>@username</span>
                    </a>
                    @if (role == "Admin" || role == "Employee")
                    {
                        <a href="/Admin/Reports" class="action-btn" style="background: rgba(239, 68, 68, 0.2); color: #fca5a5;">
                            <i class="bi bi-shield-lock"></i>
                            <span>Quản trị</span>
                        </a>
                    }
                }
            </div>
        </div>
    </header>

    @RenderBody()

    @await RenderSectionAsync("Scripts", required: false)

    <partial name="_ChatbotWidget" />
</body>
</html>
