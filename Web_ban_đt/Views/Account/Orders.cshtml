@model IEnumerable<TechStoreWeb.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700&display=swap" rel="stylesheet">
    <style>
        .account-container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 32px;
            align-items: flex-start;
        }

        /* Sidebar Navigation */
        .account-sidebar {
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 10px 30px -10px rgba(0,0,0,0.05);
            padding: 20px 16px;
            border: 1px solid rgba(0,0,0,0.02);
            position: sticky;
            top: 100px;
        }

        .account-nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 20px;
            color: #64748b;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 500;
            font-size: 15px;
            transition: all 0.2s ease;
            margin-bottom: 8px;
        }

        .account-nav-item i {
            font-size: 20px;
            transition: transform 0.2s;
        }

        .account-nav-item:hover {
            background: #f8fafc;
            color: #0f172a;
        }

        .account-nav-item:hover i {
            transform: scale(1.1);
        }

        .account-nav-item.active {
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: #ffffff;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
        }

        .account-nav-item.danger {
            color: #ef4444;
            margin-top: 20px;
            border-top: 1px solid #f1f5f9;
            border-radius: 0 0 12px 12px;
            padding-top: 24px;
        }

        .account-nav-item.danger:hover {
            background: transparent;
            color: #dc2626;
            text-decoration: underline;
        }

        /* Main Content */
        .account-content {
            background: transparent;
        }

        .page-title {
            font-family: 'Outfit', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* Order Cards */
        .order-card {
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            border: 1px solid #f1f5f9;
            margin-bottom: 24px;
            overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .order-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.06);
        }

        .order-header {
            background: #f8fafc;
            padding: 16px 24px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .order-id-date {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .order-id {
            font-family: 'Outfit', sans-serif;
            font-size: 16px;
            font-weight: 600;
            color: #0f172a;
        }

        .order-date {
            font-size: 13px;
            color: #64748b;
        }

        /* Status Badges */
        .status-badge {
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .status-pending { background: #fef3c7; color: #d97706; border: 1px solid #fde68a; }
        .status-waiting { background: #e0f2fe; color: #0284c7; border: 1px solid #bae6fd; }
        .status-pickedup { background: #dbeafe; color: #1d4ed8; border: 1px solid #bfdbfe; }
        .status-shipping { background: #cffafe; color: #0f766e; border: 1px solid #a5f3fc; }
        .status-delivered { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }
        .status-cancelled { background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca; }

        /* Order Items */
        .order-items {
            padding: 0 24px;
        }

        .order-item {
            display: flex;
            align-items: center;
            padding: 20px 0;
            border-bottom: 1px dashed #e2e8f0;
            gap: 20px;
        }

        .order-item:last-child {
            border-bottom: none;
        }

        .item-image {
            width: 70px;
            height: 70px;
            border-radius: 12px;
            object-fit: contain;
            background: #f8fafc;
            border: 1px solid #f1f5f9;
            padding: 4px;
        }

        .item-details {
            flex: 1;
        }

        .item-name {
            font-size: 15px;
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 4px;
        }

        .item-meta {
            font-size: 13px;
            color: #64748b;
        }

        .item-price-col {
            text-align: right;
            display: flex;
            flex-direction: column;
            gap: 8px;
            align-items: flex-end;
        }

        .item-total {
            font-weight: 600;
            font-size: 15px;
            color: #0f172a;
        }

        .btn-review {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            background: #eff6ff;
            color: #2563eb;
            border: 1px solid #bfdbfe;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            transition: all 0.2s;
            cursor: pointer;
        }

        .btn-review:hover {
            background: #2563eb;
            color: #ffffff;
            border-color: #2563eb;
        }

        /* Order Footer */
        .order-footer {
            padding: 20px 24px;
            background: #ffffff;
            border-top: 1px solid #f1f5f9;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 16px;
        }

        .total-label {
            font-size: 15px;
            color: #64748b;
            font-weight: 500;
        }

        .total-amount {
            font-family: 'Outfit', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: #ef4444;
        }

        /* Empty State */
        .empty-state {
            background: #ffffff;
            border-radius: 20px;
            padding: 60px 20px;
            text-align: center;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            border: 1px solid #f1f5f9;
        }

        .empty-icon {
            font-size: 64px;
            color: #cbd5e1;
            margin-bottom: 20px;
        }

        .empty-text {
            font-size: 16px;
            color: #64748b;
            margin-bottom: 30px;
        }

        .btn-shop {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 14px 28px;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: #ffffff;
            border-radius: 12px;
            font-weight: 600;
            font-size: 15px;
            transition: all 0.3s;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
        }

        .btn-shop:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
        }

        /* Responsive */
        @@media (max-width: 900px) {
            .account-container {
                grid-template-columns: 1fr;
            }
            .account-sidebar {
                position: static;
                display: flex;
                flex-wrap: wrap;
                gap: 10px;
                padding: 12px;
            }
            .account-nav-item {
                margin: 0;
                flex: 1;
                justify-content: center;
                min-width: 140px;
                padding: 10px;
            }
            .account-nav-item.danger {
                margin: 0;
                border: none;
                padding: 10px;
                border-radius: 12px;
            }
        }
    </style>
}

<div class="account-container">
    <!-- Sidebar -->
    <div class="account-sidebar">
        <a href="/Account/Profile" class="account-nav-item">
            <i class="bi bi-person-circle"></i> Thông tin cá nhân
        </a>
        <a href="/Account/Orders" class="account-nav-item active">
            <i class="bi bi-box-seam-fill"></i> Đơn hàng của tôi
        </a>
        <a href="/Account/Logout" class="account-nav-item danger">
            <i class="bi bi-box-arrow-right"></i> Đăng xuất
        </a>
    </div>

    <!-- Content -->
    <div class="account-content">
        <h2 class="page-title"><i class="bi bi-clock-history text-primary"></i> Lịch sử đơn hàng</h2>
        
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-box2-heart empty-icon"></i>
                <p class="empty-text">Bạn chưa có đơn hàng nào. Hãy khám phá các sản phẩm tuyệt vời của chúng tôi!</p>
                <a href="/" class="btn-shop">
                    <i class="bi bi-cart"></i> Mua sắm ngay
                </a>
            </div>
        }
        else
        {
            foreach (var order in Model)
            {
                <div class="order-card">
                    <!-- Order Header -->
                    <div class="order-header">
                        <div class="order-id-date">
                            <span class="order-id">Mã đơn: #@order.OrderId</span>
                            <span class="order-date"><i class="bi bi-calendar-event"></i> @order.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <div>
                            @{
                                var statusClass = "status-pending";
                                var statusText = order.Status;
                                switch (order.Status)
                                {
                                    case "Pending": case "Chờ xử lý": statusClass = "status-pending"; statusText = "Chờ xử lý"; break;
                                    case "WaitingForPickup": statusClass = "status-waiting"; statusText = "Chờ lấy hàng"; break;
                                    case "PickedUp": statusClass = "status-pickedup"; statusText = "Đã lấy hàng"; break;
                                    case "Shipping": statusClass = "status-shipping"; statusText = "Đang vận chuyển"; break;
                                    case "Delivered": case "Thành công": statusClass = "status-delivered"; statusText = "Đã giao"; break;
                                    case "Cancelled": case "Đã hủy": statusClass = "status-cancelled"; statusText = "Đã hủy"; break;
                                }
                            }
                            <span class="status-badge @statusClass">@statusText</span>
                        </div>
                    </div>

                    <!-- Order Items -->
                    <div class="order-items">
                        @foreach (var detail in order.OrderDetails)
                        {
                            <div class="order-item">
                                <img src="@detail.Product.ImageUrl" alt="@detail.Product.Name" class="item-image" />
                                <div class="item-details">
                                    <div class="item-name">@detail.Product.Name</div>
                                    <div class="item-meta">Số lượng: @detail.Quantity x @detail.UnitPrice.ToString("N0") đ</div>
                                </div>
                                <div class="item-price-col">
                                    <div class="item-total">@((detail.Quantity * detail.UnitPrice).ToString("N0")) đ</div>
                                    @if (order.Status == "Delivered" || order.Status == "Thành công")
                                    {
                                        <a href="/Reviews/Create?productId=@detail.ProductId" class="btn-review">
                                            <i class="bi bi-star-fill text-warning" style="font-size: 11px;"></i> Đánh giá
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Order Footer -->
                    <div class="order-footer">
                        <span class="total-label">Tổng cộng:</span>
                        <span class="total-amount">@order.TotalAmount.ToString("N0") đ</span>
                    </div>
                </div>
            }
        }
    </div>
</div>
