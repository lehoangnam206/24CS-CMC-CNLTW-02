@model IEnumerable<TechStoreWeb.Models.Product>

@{
    ViewData["Title"] = "Trang chủ";
    var categories = ViewBag.Categories as IEnumerable<TechStoreWeb.Models.Category>;
}

<div class="row">
    <div class="col-md-3">
        <div class="bg-white rounded shadow-sm pb-2">
            <div class="sidebar-menu">
                <a href="/Home/Index" class="d-flex justify-content-between align-items-center fw-bold text-techblue">
                    Danh mục
                </a>

                @* Dynamic categories with hover & link to filter *@
                <div class="list-group list-group-flush">
                    @if (categories != null)
                    {
                        foreach (var cat in categories)
                        {
                            <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="/Home/Index?categoryId=@cat.CategoryId">@cat.CategoryName <i class="bi bi-chevron-right"></i></a>
                        }
                    }
                    else
                    {
                        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="#">Samsung <i class="bi bi-chevron-right"></i></a>
                        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="#">Oppo <i class="bi bi-chevron-right"></i></a>
                        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="#">Honor <i class="bi bi-chevron-right"></i></a>
                        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="#">Xiaomi <i class="bi bi-chevron-right"></i></a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="row mb-3">
            <div class="col-12">
                <div class="text-white rounded p-0 home-banner" style="height: 220px;">
                    <img src="https://via.placeholder.com/900x220/1a56db/ffffff?text=ĐỈNH+CAO+CÔNG+NGHỆ" class="img-fluid rounded w-100 h-100" style="object-fit:cover;">
                </div>
            </div>
        </div>

        <div class="row mb-4 g-3">
            <div class="col-md-4">
                <div class="card p-2 promo-card">
                    <img src="https://via.placeholder.com/300x120?text=Promo+1" class="img-fluid rounded">
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-2 promo-card">
                    <img src="https://via.placeholder.com/300x120?text=Promo+2" class="img-fluid rounded">
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-2 promo-card">
                    <img src="https://via.placeholder.com/300x120?text=Promo+3" class="img-fluid rounded">
                </div>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-md-4 g-3">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 product-card text-center p-3">
                        <img src="@item.ImageUrl" class="card-img-top mx-auto mb-3" alt="@item.Name" style="height: 120px; object-fit: contain;">
                        <div class="card-body p-0 d-flex flex-column">
                            <h6 class="card-title text-truncate mb-2" style="font-size: 14px;" title="@item.Name">@item.Name</h6>

                            <p class="text-danger fw-bold mb-3 mt-auto">@item.Price.ToString("N0") VNĐ</p>

                            <form asp-controller="Cart" asp-action="Add" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.ProductId" />
                                <input type="hidden" name="name" value="@item.Name" />
                                <input type="hidden" name="price" value="@item.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                <input type="hidden" name="img" value="@item.ImageUrl" />
                                <button type="submit" class="btn btn-sm btn-techblue w-100 mt-auto">Thêm vào giỏ</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
