@model TechStoreWeb.Models.User
@{
    ViewData["Title"] = "Thêm Nhân viên";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1 text-techblue fw-bold">Thêm Nhân viên mới</h3>
        <p class="text-muted mb-0">Tạo tài khoản cho nhân viên</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 10px; padding: 10px 20px; font-weight: 500;">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

<div class="card shadow-sm border-0" style="border-radius: 16px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="FullName" class="form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                    <input asp-for="FullName" class="form-control" required />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Username" class="form-label fw-bold">Tên đăng nhập <span class="text-danger">*</span></label>
                    <input asp-for="Username" class="form-control" required />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                    <input asp-for="Email" class="form-control" type="email" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PhoneNumber" class="form-label fw-bold">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Password" class="form-label fw-bold">Mật khẩu <span class="text-danger">*</span></label>
                    <input asp-for="Password" type="password" class="form-control" required />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Role" class="form-label fw-bold">Quyền</label>
                    <select asp-for="Role" class="form-select">
                        <option value="Employee">Nhân viên</option>
                        <option value="Admin">Quản trị viên (Admin)</option>
                    </select>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-4 py-2" style="border-radius: 8px;">
                    <i class="bi bi-save me-1"></i> Lưu thông tin
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
