<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechStore</title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        /* 1. Global Styles & Variables */
        :root {
            --primary-color: #2563eb;
            --primary-hover: #1d4ed8;
            --bg-color: #f8fafc;
            --surface-color: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
            --shadow-hover: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
            --radius-md: 12px;
            --radius-lg: 16px;
            --transition-speed: 0.3s;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            text-decoration: none;
            list-style: none;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
        }

        /* Loại bỏ nền xanh của Chrome Autofill cho tất cả ô nhập liệu */
        input:-webkit-autofill,
        input:-webkit-autofill:hover, 
        input:-webkit-autofill:focus, 
        input:-webkit-autofill:active {
            transition: background-color 50000s ease-in-out 0s;
            -webkit-text-fill-color: var(--text-main) !important;
        }

        .container {
            width: 100%;
            max-width: 1920px; /* Tràn viền màn hình lớn như trước */
            margin: 0 auto;
            padding: 0 20px;
        }

        /* 2. Header (Glassmorphism) */
        .site-header {
            height: 72px;
            background-color: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            box-shadow: var(--shadow-sm);
            transition: background-color var(--transition-speed) ease;
        }

        .site-header .container {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 24px;
            align-items: center;
            height: 100%;
        }

        .header-logo {
            display: inline-flex;
            align-items: center;
            transition: transform var(--transition-speed) cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        
        .header-logo:hover {
            transform: scale(1.03);
        }

        .header-logo img {
            height: 44px;
            border-radius: 8px;
            object-fit: contain;
        }

        .search-bar-container {
            display: flex;
            min-width: 450px;
            border-radius: 24px;
            overflow: hidden;
            background-color: #f1f5f9;
            height: 44px;
            border: 1px solid transparent;
            transition: all var(--transition-speed) ease;
        }
        
        .search-bar-container:focus-within {
            background-color: var(--surface-color);
            border-color: #cbd5e1;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
        }

        .search-bar-container input {
            flex: 1;
            border: none;
            padding: 0 20px;
            outline: none;
            font-size: 14px;
            color: var(--text-main);
            background: transparent;
            font-family: inherit;
        }

        .search-bar-container button {
            background-color: transparent;
            border: none;
            padding: 0 20px;
            cursor: pointer;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: color var(--transition-speed);
        }
        
        .search-bar-container button:hover {
            color: var(--primary-color);
        }

        .header-actions {
            display: flex;
            gap: 28px;
            align-items: center;
        }

        .header-actions .action-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            font-weight: 500;
            color: var(--text-main);
            transition: all 0.2s ease;
            position: relative;
        }

        .header-actions .action-item:hover {
            color: var(--primary-color);
            transform: translateY(-1px);
        }

        .header-actions .action-item i {
            font-size: 22px;
            color: var(--text-muted);
            transition: color 0.2s ease;
        }
        
        .header-actions .action-item:hover i {
            color: var(--primary-color);
        }

        .cart-badge {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            color: white;
            border-radius: 20px;
            padding: 0 6px;
            font-size: 11px;
            font-weight: 600;
            position: absolute;
            top: -6px;
            right: -10px;
            height: 18px;
            min-width: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 2px solid var(--surface-color);
            box-shadow: 0 2px 4px rgba(239, 68, 68, 0.3);
            animation: pulse 2s infinite;
        }
        
        @@keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
            70% { box-shadow: 0 0 0 6px rgba(239, 68, 68, 0); }
            100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
        }

        /* Main Layout Grid */
        .main-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 28px;
            padding: 32px 0;
        }

        /* 4. Cột trái (Sidebar Menu) */
        .sidebar-wrapper {
            background-color: var(--surface-color);
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            position: sticky;
            top: 104px;
            z-index: 900;
            align-self: start;
            display: flex;
            flex-direction: column;
            border: 1px solid rgba(0,0,0,0.03);
            transition: box-shadow var(--transition-speed);
        }
        
        .sidebar-wrapper:hover {
            box-shadow: var(--shadow-md);
        }

        .sidebar-title {
            padding: 20px 24px;
            font-weight: 600;
            font-size: 18px;
            border-bottom: 1px solid #f1f5f9;
            color: var(--text-main);
            background-color: #fafafa;
        }

        .sidebar-menu {
            margin: 0;
            padding: 8px 0;
            list-style-type: none;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .sidebar-menu li {
            padding: 2px 12px;
        }

        .sidebar-menu li a {
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: var(--text-main);
            font-size: 16px;
            font-weight: 500;
            border-radius: 8px;
            transition: all var(--transition-speed) ease;
        }

        .sidebar-menu li a:hover {
            background-color: #eff6ff;
            color: var(--primary-color);
            transform: translateX(4px);
        }

        .sidebar-menu li a i {
            font-size: 14px;
            color: #cbd5e1;
            transition: all var(--transition-speed) ease;
        }

        .sidebar-menu li a:hover i {
            color: var(--primary-color);
            transform: translateX(2px);
        }

        footer {
            text-align: center;
            padding: 32px 24px;
            color: var(--text-muted);
            font-size: 14px;
            background-color: var(--surface-color);
            border-top: 1px solid #e2e8f0;
            margin-top: 60px;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
<style>* { font-family: 'Times New Roman', Times, serif !important; }</style></head>
<body>
    <header class="site-header">
        <div class="container">
            <!-- Cột 1: Logo thẳng hàng với Sidebar -->
            <div style="display: flex; align-items: center;">
                <a href="/" class="header-logo" style="display: flex; align-items: center; gap: 12px;">
                    <img src="~/images/logo.png" asp-append-version="true" alt="TECHBLUE" style="height: 44px; border-radius: 12px; object-fit: contain;" />
                    <span style="font-size: 24px; font-weight: 800; color: var(--primary-color); letter-spacing: -0.5px; line-height: 1;">TECH<span style="color: #1e293b;">BLUE</span></span>
                </a>
            </div>

            <!-- Cột 2: Search Bar & Actions thẳng hàng với Banner -->
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <form action="/Home/Index" method="get" class="search-bar-container" style="flex: 1; margin-right: 24px;">
                    <input type="text" name="searchString" placeholder="Hôm nay bạn muốn tìm kiếm gì?" value="@((string)ViewData["SearchString"] ?? Context.Request.Query["searchString"])" />
                    <button type="submit"><i class="bi bi-search" style="margin-right: 6px;"></i> Tìm kiếm</button>
                </form>

                <div class="header-actions">

                    
                    @{
                        var username = Context.Session.GetString("Username");
                        var role = Context.Session.GetString("Role");
                    }
                    @if (string.IsNullOrEmpty(username))
                    {
                        <a href="/Account/Login" class="action-item">
                            <i class="bi bi-person-circle"></i>
                            <span>Đăng nhập</span>
                        </a>
                    }
                    else
                    {
                        <a href="/Account/Profile" class="action-item">
                            <i class="bi bi-person-circle"></i>
                            <span>@username</span>
                        </a>
                        @if (role == "Admin" || role == "Employee")
                        {
                            <a href="/Admin/Reports" class="action-item" style="color: #ef4444;">
                                <i class="bi bi-shield-lock"></i>
                                <span>Quản trị</span>
                            </a>
                        }
                    }

                    @{ 
                        var _cart = Context.Session.GetString("Cart");
                        int _qty = 0;
                        if (!string.IsNullOrEmpty(_cart))
                        {
                            try {
                                var _list = System.Text.Json.JsonSerializer.Deserialize<List<TechStoreWeb.Models.CartItem>>(_cart);
                                if (_list != null) _qty = _list.Sum(i=>i.Qty);
                            } catch {}
                        }
                    }
                    <a href="/Cart/Index" class="action-item">
                        <i class="bi bi-cart3"></i>
                        <span>Giỏ hàng</span>
                        <span class="cart-badge">@_qty</span>
                    </a>
                </div>
            </div>
        </div>
    </header>

    @RenderBody()


    @await RenderSectionAsync("Scripts", required: false)

    <!--Start of Tawk.to Script-->
