@model IEnumerable<TechStoreWeb.Models.User>
@{
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1 text-techblue fw-bold">Danh sách Nhân viên</h3>
        <p class="text-muted mb-0">Quản lý tài khoản nhân viên</p>
    </div>
    <a asp-action="Create" class="btn btn-primary" style="border-radius: 8px;">
        <i class="bi bi-plus-lg me-1"></i> Thêm Nhân viên
    </a>
</div>

<div class="card shadow-sm border-0" style="border-radius: 16px; overflow: hidden;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background-color: #f8fafc;">
                    <tr>
                        <th class="border-0 px-4 py-3 text-muted fw-semibold">ID</th>
                        <th class="border-0 px-4 py-3 text-muted fw-semibold">Tài khoản</th>
                        <th class="border-0 px-4 py-3 text-muted fw-semibold">Họ tên</th>
                        <th class="border-0 px-4 py-3 text-muted fw-semibold">Email</th>
                        <th class="border-0 px-4 py-3 text-muted fw-semibold text-center">Quyền</th>
                        <th class="border-0 px-4 py-3 text-muted fw-semibold text-center">Trạng thái</th>
                        <th class="border-0 px-4 py-3 text-muted fw-semibold text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model) {
                        <tr style="transition: background-color 0.2s;">
                            <td class="px-4 py-3 border-bottom-0 text-muted" style="border-bottom: 1px solid #f1f5f9 !important;">#@user.UserId</td>
                            <td class="px-4 py-3 border-bottom-0" style="border-bottom: 1px solid #f1f5f9 !important;">
                                <div class="d-flex align-items-center">
                                    @{
                                        var displayStr = !string.IsNullOrEmpty(user.Username) ? user.Username : (!string.IsNullOrEmpty(user.FullName) ? user.FullName : "?");
                                        var initial = displayStr.Substring(0, 1).ToUpper();
                                        var displayName = !string.IsNullOrEmpty(user.Username) ? user.Username : "N/A";
                                    }
                                    <div style="width: 36px; height: 36px; border-radius: 50%; background: #eff6ff; color: #2563eb; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-right: 12px;">
                                        @initial
                                    </div>
                                    <span class="fw-bold" style="color: #1e293b;">@displayName</span>
                                </div>
                            </td>
                            <td class="px-4 py-3 border-bottom-0 fw-medium" style="border-bottom: 1px solid #f1f5f9 !important; color: #334155;">@user.FullName</td>
                            <td class="px-4 py-3 border-bottom-0 text-muted" style="border-bottom: 1px solid #f1f5f9 !important;">@user.Email</td>
                            <td class="px-4 py-3 border-bottom-0 text-center" style="border-bottom: 1px solid #f1f5f9 !important;">
                                @if (user.Role == "Admin") { 
                                    <span class="badge" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 6px 12px; border-radius: 20px;">Admin</span> 
                                } else if (user.Role == "Employee") {
                                    <span class="badge" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9; padding: 6px 12px; border-radius: 20px;">Nhân viên</span> 
                                } else { 
                                    <span class="badge" style="background: #f1f5f9; color: #64748b; padding: 6px 12px; border-radius: 20px;">Khách hàng</span> 
                                }
                            </td>
                            <td class="px-4 py-3 border-bottom-0 text-center" style="border-bottom: 1px solid #f1f5f9 !important;">
                                @if (user.IsLocked) { 
                                    <span class="badge" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; padding: 6px 12px; border-radius: 20px;"><i class="bi bi-lock-fill me-1"></i>Bị khóa</span> 
                                } else { 
                                    <span class="badge" style="background: rgba(16, 185, 129, 0.1); color: #10b981; padding: 6px 12px; border-radius: 20px;"><i class="bi bi-unlock-fill me-1"></i>Hoạt động</span> 
                                }
                            </td>
                            <td class="px-4 py-3 border-bottom-0 text-end" style="border-bottom: 1px solid #f1f5f9 !important;">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Details" asp-route-id="@user.UserId" class="btn btn-sm text-info" style="background: #e0f2fe; border-radius: 8px;" title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@user.UserId" class="btn btn-sm text-primary" style="background: #e0e7ff; border-radius: 8px;" title="Chỉnh sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (user.Role != "Admin")
                                    {
                                        <form asp-action="ToggleLock" asp-route-id="@user.UserId" method="post" style="display:inline;">
                                            <button type="submit" class="btn btn-sm text-warning" style="background: #fef3c7; border-radius: 8px;" title="@(user.IsLocked ? "Mở khóa" : "Khóa tài khoản")">
                                                <i class="bi @(user.IsLocked ? "bi-unlock" : "bi-lock")"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .btn-sm:hover {
        filter: brightness(0.95);
        transform: translateY(-1px);
    }
</style>
