@model TechStoreWeb.Models.Order
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thanh toán bằng mã QR - TechStore</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        :root {
            --primary: #4361ee;
            --primary-gradient: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%);
            --text-main: #1e293b;
            --text-muted: #64748b;
            --danger: #ef4444;
            --bg-color: #f8fafc;
        }

        body {
            background-color: var(--bg-color);
            background-image: 
                radial-gradient(at 0% 0%, hsla(228, 100%, 74%, 0.1) 0px, transparent 50%),
                radial-gradient(at 100% 100%, hsla(260, 100%, 70%, 0.05) 0px, transparent 50%);
            background-attachment: fixed;
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 40px 20px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            margin-bottom: 40px;
        }

        .brand-logo img {
            height: 48px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(67, 97, 238, 0.2);
        }

        .brand-logo span {
            font-family: 'Outfit', sans-serif;
            font-size: 32px;
            font-weight: 800;
            color: var(--text-main);
            letter-spacing: -1px;
        }
        .brand-logo span span { color: var(--primary); }

        .payment-container {
            width: 100%;
            max-width: 900px;
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 30px;
            align-items: stretch;
        }

        .payment-card {
            background: #ffffff;
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.05);
            border: 1px solid rgba(255,255,255,0.6);
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }



        .card-title {
            font-family: 'Outfit', sans-serif;
            font-size: 26px;
            font-weight: 800;
            color: var(--text-main);
            margin: 0 0 10px 0;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .card-subtitle {
            font-size: 15px;
            color: var(--text-muted);
            margin: 0 0 32px 0;
            line-height: 1.6;
        }

        /* Left Column - Bank Info */
        .info-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
            flex: 1;
        }

        .info-item {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 16px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .info-item.highlight {
            background: #eff6ff;
            border-color: #bfdbfe;
        }

        .info-label {
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 600;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .info-value {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-main);
        }

        .info-value.amount {
            font-size: 24px;
            color: var(--danger);
            font-family: 'Outfit', sans-serif;
        }

        .copy-btn {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            color: var(--primary);
            cursor: pointer;
            font-size: 18px;
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }
        .copy-btn:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .note-box {
            background: #fffbeb;
            border: 1px solid #fde68a;
            border-radius: 16px;
            padding: 20px;
            margin-top: 24px;
            display: flex;
            gap: 16px;
            align-items: flex-start;
        }
        .note-box i { color: #d97706; font-size: 24px; }
        .note-box p { margin: 0; font-size: 14px; color: #92400e; line-height: 1.6; font-weight: 500; }

        /* Right Column - QR Code */
        .qr-wrapper {
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
            align-items: center;
            text-align: center;
        }

        .qr-container {
            width: 280px;
            height: auto;
            background: transparent;
            border-radius: 24px;
            padding: 0;
            box-shadow: 0 10px 30px rgba(67, 97, 238, 0.1);
            border: 1px solid #e2e8f0;
            margin-bottom: 24px;
            position: relative;
            overflow: hidden;
        }
        .qr-container img { width: 100%; height: auto; display: block; object-fit: contain; }

        .qr-instruction {
            font-size: 15px;
            color: var(--text-muted);
            margin-bottom: 24px;
            line-height: 1.6;
        }

        .qr-logos {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-top: auto;
        }
        .qr-logos span { font-family: 'Outfit', sans-serif; font-weight: 800; font-size: 20px; }
        .qr-logos .vietqr { color: var(--danger); }
        .qr-logos .napas { color: var(--primary); }

        /* Actions */
        .action-container {
            width: 100%;
            max-width: 900px;
            margin-top: 30px;
            display: flex;
            justify-content: flex-end;
            gap: 16px;
        }

        .btn {
            padding: 16px 32px;
            border-radius: 14px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn-outline {
            background: #ffffff;
            color: var(--text-main);
            border: 1px solid #e2e8f0;
        }
        .btn-outline:hover { background: #f8fafc; border-color: #cbd5e1; }

        .btn-primary {
            background: var(--primary-gradient);
            color: white;
            border: none;
            box-shadow: 0 8px 20px rgba(67, 97, 238, 0.3);
        }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 25px rgba(67, 97, 238, 0.4); }

        @@media (max-width: 768px) {
            .payment-container { grid-template-columns: 1fr; }
            .action-container { flex-direction: column; }
            .btn { justify-content: center; }
        }
    </style>
</head>
<body>
    
    <a href="/" class="brand-logo">
        <img src="~/images/logo.png" alt="TECHBLUE" />
        <span>TECH<span>BLUE</span></span>
    </a>

    <div class="payment-container">
        
        <div class="payment-card">
            <h2 class="card-title"><i class="bi bi-wallet2 text-primary"></i> Thông tin chuyển khoản</h2>
            <p class="card-subtitle">Vui lòng chuyển khoản đúng số tiền và nội dung để hệ thống tự động xác nhận đơn hàng của bạn.</p>
            
            <div class="info-list">
                <div class="info-item">
                    <div>
                        <div class="info-label">Ngân hàng</div>
                        <div class="info-value">Ngân hàng MB Bank</div>
                    </div>
                </div>
                <div class="info-item">
                    <div>
                        <div class="info-label">Chủ tài khoản</div>
                        <div class="info-value">NGUYEN DUC BINH</div>
                    </div>
                </div>
                <div class="info-item">
                    <div>
                        <div class="info-label">Số tài khoản</div>
                        <div class="info-value">0812285479</div>
                    </div>
                    <button class="copy-btn" onclick="copyText('0812285479')" title="Sao chép">
                        <i class="bi bi-copy"></i>
                    </button>
                </div>
                <div class="info-item">
                    <div>
                        <div class="info-label">Số tiền</div>
                        <div class="info-value amount">@Model.TotalAmount.ToString("N0") đ</div>
                    </div>
                    <button class="copy-btn" onclick="copyText('@Model.TotalAmount')" title="Sao chép">
                        <i class="bi bi-copy"></i>
                    </button>
                </div>
                <div class="info-item highlight">
                    <div>
                        <div class="info-label" style="color: var(--primary);">Nội dung chuyển khoản (Bắt buộc)</div>
                        <div class="info-value">Thanh toan don hang #@Model.OrderId</div>
                    </div>
                    <button class="copy-btn" onclick="copyText('Thanh toan don hang #@Model.OrderId')" title="Sao chép">
                        <i class="bi bi-copy"></i>
                    </button>
                </div>
            </div>

            <div class="note-box">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <p><strong>Lưu ý quan trọng:</strong> Bắt buộc phải nhập đúng Nội dung chuyển khoản. Đơn hàng sẽ tự động xác nhận trong 3-5 phút.</p>
            </div>
        </div>

        <div class="qr-wrapper payment-card">
            <div class="card-title" style="margin-bottom: 24px;"><i class="bi bi-qr-code-scan text-primary"></i> Quét mã thanh toán</div>
            
            <div class="qr-container">
                <img src="@Url.Content("~/images/Giao diện trang chủ/Ảnh QR.jpg")" alt="QR Code" onerror="this.src='https://via.placeholder.com/280?text=QR+Code'" />
            </div>
            
            <p class="qr-instruction">
                Mở ứng dụng Ngân hàng trên điện thoại và quét mã QR để điền thông tin tự động.
            </p>

            <div class="qr-logos">
                <span class="vietqr">VIET<span>QR</span></span>
                <span class="napas">napas <span style="color: #10b981;">247</span></span>
            </div>
        </div>
    </div>

    <div class="action-container">
        <a href="/Cart/Index" class="btn btn-outline"><i class="bi bi-arrow-left"></i> Quay lại giỏ hàng</a>
        <a href="/Cart/Confirm/@Model.OrderId" class="btn btn-primary">Xác nhận đã thanh toán <i class="bi bi-check2-circle"></i></a>
    </div>

    <script>
        function copyText(text) {
            navigator.clipboard.writeText(text).then(() => {
                const toast = document.createElement('div');
                toast.innerHTML = '<i class="bi bi-check-circle-fill"></i> Đã sao chép';
                toast.style.cssText = 'position:fixed;bottom:40px;left:50%;transform:translateX(-50%);background:#10b981;color:#fff;padding:12px 24px;border-radius:30px;font-weight:600;box-shadow:0 10px 25px rgba(16,185,129,0.3);z-index:9999;transition:opacity 0.3s;display:flex;align-items:center;gap:8px;';
                document.body.appendChild(toast);
                setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 2000);
            });
        }
    </script>
</body>
</html>
