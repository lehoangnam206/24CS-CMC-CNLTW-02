@model IEnumerable<TechStoreWeb.Models.Order>
@{
    ViewData["Title"] = "Báo cáo Thống kê";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0 text-techblue">Báo cáo Thống kê</h3>
    @if (Model != null && Model.Any())
    {
        <button onclick="window.print()" class="btn btn-secondary"><i class="bi bi-printer"></i> In Báo cáo</button>
    }
</div>

@if (ViewBag.Message != null)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i> @ViewBag.Message
    </div>
}
else if (Model != null && Model.Any())
{
    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-6 mb-3">
            <div class="report-card report-card-orders">
                <div class="report-card-icon">
                    <i class="bi bi-cart-check-fill"></i>
                </div>
                <div class="report-card-content">
                    <span class="report-card-label">Tổng đơn hàng</span>
                    <span class="report-card-value">@String.Format("{0:N0}", ViewBag.TotalOrders)</span>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="report-card report-card-revenue">
                <div class="report-card-icon">
                    <i class="bi bi-cash-stack"></i>
                </div>
                <div class="report-card-content">
                    <span class="report-card-label">Tổng doanh thu</span>
                    <span class="report-card-value">@String.Format("{0:N0}", ViewBag.TotalRevenue) VNĐ</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Bar Chart -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 fw-bold">Thống kê đơn hàng theo ngày trong tuần</h5>
                <div class="btn-group btn-group-sm" role="group" style="position: relative; z-index: 10;">
                    <button type="button" class="btn btn-outline-primary active" id="btnOrders" onclick="switchChart('orders')">Đơn hàng</button>
                    <button type="button" class="btn btn-outline-primary" id="btnRevenue" onclick="switchChart('revenue')">Doanh thu</button>
                </div>
            </div>
            <div class="chart-container" id="chartContainer" style="position: relative; z-index: 1;">
                <!-- Chart sẽ được render bằng JS -->
            </div>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h5 class="mb-3 fw-bold">Danh sách Đơn hàng Gần đây</h5>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Khách hàng</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td><span class="fw-bold">#@order.OrderId</span></td>
                                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@order.User.FullName</td>
                                <td class="text-danger fw-bold">@order.TotalAmount.ToString("N0")</td>
                                <td>
                                    @{
                                        var badgeClass = "bg-secondary";
                                        var statusText = order.Status;
                                        switch (order.Status)
                                        {
                                            case "Pending": badgeClass = "bg-warning text-dark"; statusText = "Chờ xử lý"; break;
                                            case "WaitingForPickup": badgeClass = "bg-info text-dark"; statusText = "Chờ lấy hàng"; break;
                                            case "PickedUp": badgeClass = "bg-primary"; statusText = "Đã lấy hàng"; break;
                                            case "Shipping": badgeClass = "bg-info"; statusText = "Đang vận chuyển"; break;
                                            case "Delivered": badgeClass = "bg-success"; statusText = "Đã giao"; break;
                                            case "Cancelled": badgeClass = "bg-danger"; statusText = "Đã hủy"; break;
                                        }
                                    }
                                    <span class="badge @badgeClass">@statusText</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<style>
    /* ===== Summary Cards ===== */
    .report-card {
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 24px 28px;
        border-radius: 16px;
        color: #fff;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0,0,0,.12);
        transition: transform .2s, box-shadow .2s;
    }
    .report-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0,0,0,.18);
    }
    .report-card-orders {
        background: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%);
    }
    .report-card-revenue {
        background: linear-gradient(135deg, #06d6a0 0%, #118ab2 100%);
    }
    .report-card-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        background: rgba(255,255,255,.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        flex-shrink: 0;
        backdrop-filter: blur(4px);
    }
    .report-card-content {
        display: flex;
        flex-direction: column;
    }
    .report-card-label {
        font-size: .9rem;
        font-weight: 500;
        opacity: .9;
        text-transform: uppercase;
        letter-spacing: .4px;
    }
    .report-card-value {
        font-size: 1.6rem;
        font-weight: 700;
        line-height: 1.3;
    }

    /* ===== Bar Chart ===== */
    .chart-container {
        width: 100%;
        padding: 20px 10px 0;
    }
    .chart-wrapper {
        display: block;
        height: 320px;
        position: relative;
        margin-left: 55px;
    }
    /* Y-axis grid */
    .chart-y-axis {
        position: absolute;
        left: -55px;
        top: 0;
        bottom: 40px;
        width: 55px;
        display: flex;
        flex-direction: column-reverse;
        justify-content: space-between;
    }
    .chart-y-label {
        font-size: .78rem;
        color: #9ca3af;
        text-align: right;
        padding-right: 10px;
        line-height: 1;
    }
    .chart-grid {
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        bottom: 40px;
    }
    .chart-grid-line {
        position: absolute;
        left: 0;
        right: 0;
        border-top: 1px solid #f1f3f5;
        height: 0;
    }
    /* Bars */
    .chart-bars {
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        bottom: 0;
        display: flex;
        align-items: flex-end;
        justify-content: space-around;
        z-index: 2;
    }
    .chart-bar-group {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
        max-width: 80px;
        height: 100%;
    }
    .chart-bar-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end;
        height: 280px;
        width: 100%;
        position: relative;
    }
    .chart-bar {
        width: 42px;
        border-radius: 8px 8px 3px 3px;
        position: relative;
        cursor: pointer;
        transition: height 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.2s, filter 0.2s;
        min-height: 4px;
        height: 0%;
    }
    .chart-bar:hover {
        filter: brightness(1.12);
        transform: scaleX(1.08);
    }
    .chart-bar-0 { background: linear-gradient(180deg, #34d399 0%, #10b981 100%); }
    .chart-bar-1 { background: linear-gradient(180deg, #4ade80 0%, #22c55e 100%); }
    .chart-bar-2 { background: linear-gradient(180deg, #6ee7b7 0%, #34d399 100%); }
    .chart-bar-3 { background: linear-gradient(180deg, #34d399 0%, #10b981 100%); }
    .chart-bar-4 { background: linear-gradient(180deg, #4ade80 0%, #22c55e 100%); }
    .chart-bar-5 { background: linear-gradient(180deg, #6ee7b7 0%, #34d399 100%); }
    .chart-bar-6 { background: linear-gradient(180deg, #22c55e 0%, #16a34a 100%); }

    .chart-bar-value {
        position: absolute;
        top: -24px;
        left: 50%;
        transform: translateX(-50%);
        font-size: .78rem;
        font-weight: 600;
        color: #374151;
        white-space: nowrap;
        opacity: 0;
        transition: opacity .2s;
    }
    .chart-bar:hover .chart-bar-value {
        opacity: 1;
    }
    .chart-bar-label {
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
        color: #6b7280;
        font-weight: 500;
        text-align: center;
        width: 100%;
        margin-top: 0;
    }

    /* Tooltip */
    .chart-tooltip {
        position: fixed;
        padding: 8px 14px;
        background: rgba(30, 41, 59, .92);
        color: #fff;
        border-radius: 8px;
        font-size: .82rem;
        pointer-events: none;
        z-index: 999;
        opacity: 0;
        transition: opacity .15s;
        white-space: nowrap;
        backdrop-filter: blur(6px);
    }
    .chart-tooltip.show { opacity: 1; }

    /* Button Group Z-Index */
    .btn-group {
        position: relative;
        z-index: 10;
    }

    /* Print */
    @@media print {
        .report-card {
            box-shadow: none !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
    }
</style>

@section Scripts {
    <script>
        // Dữ liệu từ server
        const ordersData = [@Html.Raw(string.Join(",", (int[])ViewBag.OrdersByDayOfWeek))];
        const revenueData = [@Html.Raw(string.Join(",", ((decimal[])ViewBag.RevenueByDayOfWeek).Select(r => r.ToString("0"))))];
        const dayLabels = ['Thứ 2', 'Thứ 3', 'Thứ 4', 'Thứ 5', 'Thứ 6', 'Thứ 7', 'CN'];

        let currentChart = 'orders';

        function formatNumber(n) {
            return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.');
        }

        function renderChart(dataArr, labels, isRevenue) {
            const container = document.getElementById('chartContainer');
            const maxVal = Math.max(...dataArr, 1);

            // Tính các mốc trục Y (5 mốc)
            const steps = 5;
            const niceMax = Math.ceil(maxVal / steps) * steps;
            const stepVal = niceMax / steps;

            let html = '<div class="chart-wrapper">';

            // Y axis labels
            html += '<div class="chart-y-axis">';
            for (let i = 0; i <= steps; i++) {
                const val = stepVal * i;
                const displayVal = isRevenue ? formatNumber(Math.round(val / 1000)) + 'k' : formatNumber(Math.round(val));
                html += `<div class="chart-y-label">${displayVal}</div>`;
            }
            html += '</div>';

            // Grid lines
            html += '<div class="chart-grid">';
            for (let i = 0; i <= steps; i++) {
                const pct = (i / steps) * 100;
                html += `<div class="chart-grid-line" style="bottom:${pct}%"></div>`;
            }
            html += '</div>';

            // Bars
            html += '<div class="chart-bars">';
            dataArr.forEach((val, idx) => {
                const heightPct = niceMax > 0 ? (val / niceMax) * 100 : 0;
                const displayVal = isRevenue ? formatNumber(val) + ' VNĐ' : formatNumber(val);
                html += `
                    <div class="chart-bar-group">
                        <div class="chart-bar-wrapper">
                            <div class="chart-bar chart-bar-${idx}" 
                                 style="height: 0%"
                                 data-height="${heightPct}"
                                 data-value="${displayVal}"
                                 data-label="${labels[idx]}">
                                <span class="chart-bar-value">${displayVal}</span>
                            </div>
                        </div>
                        <div class="chart-bar-label">${labels[idx]}</div>
                    </div>`;
            });
            html += '</div>';
            html += '</div>';

            container.innerHTML = html;

            // Animate bars
            requestAnimationFrame(() => {
                const bars = container.querySelectorAll('.chart-bar');
                bars.forEach((bar, i) => {
                    setTimeout(() => {
                        bar.style.height = bar.dataset.height + '%';
                    }, i * 80);
                });
            });

            // Tooltip
            setupTooltip();
        }

        function setupTooltip() {
            let tooltip = document.querySelector('.chart-tooltip');
            if (!tooltip) {
                tooltip = document.createElement('div');
                tooltip.className = 'chart-tooltip';
                document.body.appendChild(tooltip);
            }

            document.querySelectorAll('.chart-bar').forEach(bar => {
                bar.addEventListener('mouseenter', function(e) {
                    tooltip.textContent = `${this.dataset.label}: ${this.dataset.value}`;
                    tooltip.classList.add('show');
                });
                bar.addEventListener('mousemove', function(e) {
                    tooltip.style.left = (e.clientX + 12) + 'px';
                    tooltip.style.top = (e.clientY - 36) + 'px';
                });
                bar.addEventListener('mouseleave', function() {
                    tooltip.classList.remove('show');
                });
            });
        }

        function switchChart(type) {
            currentChart = type;
            document.getElementById('btnOrders').classList.toggle('active', type === 'orders');
            document.getElementById('btnRevenue').classList.toggle('active', type === 'revenue');

            if (type === 'orders') {
                document.querySelector('.card-body h5').textContent = 'Thống kê đơn hàng theo ngày trong tuần';
                renderChart(ordersData, dayLabels, false);
            } else {
                document.querySelector('.card-body h5').textContent = 'Thống kê doanh thu theo ngày trong tuần';
                renderChart(revenueData, dayLabels, true);
            }
        }

        // Render chart ban đầu
        document.addEventListener('DOMContentLoaded', function() {
            renderChart(ordersData, dayLabels, false);
        });
    </script>
}
