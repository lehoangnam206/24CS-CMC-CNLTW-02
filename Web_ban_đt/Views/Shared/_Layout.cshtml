<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechStore</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
            /* Global */
            body {
                background-color: #f4f6f9;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }

            /* Tech blue */
            .bg-techblue {
                background-color: #1a56db !important;
            }

            .text-techblue {
                color: #1a56db;
            }

            /* Header layout: three columns like the design */
            .site-header {
                display: grid;
                grid-template-columns: 180px 1fr 260px;
                align-items: center;
                gap: 16px;
            }

            /* Rounded search bar centered */
            .search-bar {
                border-radius: 24px;
                overflow: hidden;
                max-width: 820px;
                width: 100%;
                background-color: white;
                box-shadow: 0 2px 6px rgba(0,0,0,0.06);
            }

            .search-bar .form-control {
                border: none;
                outline: none;
                box-shadow: none !important;
                height: 44px;
            }

            .search-bar .input-group-text {
                background: white;
                border: none;
            }

            /* Header right area */
            .header-actions a { color: #fff; text-decoration: none; }
            .header-actions .action-item { display:inline-flex; align-items:center; gap:8px; padding:6px 8px; }

            /* Cart badge */
            .cart-badge { font-size: 11px; }

            /* Sidebar / left menu styling to match screenshot */
            .sidebar-menu .list-group-item {
                border: none;
                padding: 14px 18px;
                font-weight: 500;
                color: #111827;
                border-bottom: 1px solid #f1f5f9;
                background: transparent;
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-radius: 0;
            }

            .sidebar-menu .list-group-item:hover {
                background: #f8fafc;
                color: #1a56db;
            }

            /* Banner and promo cards */
            .home-banner img { border-radius: 8px; }
            .promo-card img { border-radius: 8px; }

            /* Product card smaller padding to mimic screenshot */
            .product-card { padding: 16px; }

            /* Cart table tweaks */
            #cartTable img { width: 56px; height:56px; object-fit:cover; border-radius:6px; }
            #cartTable .qty { min-width: 28px; display:inline-block; text-align:center; }
            #cartTable .btn-light { width:34px; height:34px; padding:0; }

            /* Voucher input style like screenshot (grey box centered) */
            .voucher-box { background:#f1f5f9; border-radius:6px; padding:12px; text-align:center; }

            /* Footer */
            footer { background-color: white; border-top: 1px solid #e5e7eb; color: #6b7280; font-size: 14px; }
    </style>
</head>
<body>
    <header class="bg-techblue py-3 sticky-top shadow-sm">
        <div class="container site-header">

            <div class="d-flex align-items-center text-white">
                <a href="/Home/Index" class="d-flex align-items-center text-white text-decoration-none">
                    <i class="bi bi-list fs-3 me-2"></i>
                    <span class="fw-bold fs-5">Danh mục</span>
                </a>
            </div>

            <div class="d-flex justify-content-center">
                <form action="/Home/Index" method="get" class="input-group search-bar">
                    <span class="input-group-text"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="searchString" class="form-control" placeholder="Tìm kiếm sản phẩm" value="@((string)ViewData["SearchString"] ?? Context.Request.Query["searchString"])" />
                </form>
            </div>

            <div class="d-flex justify-content-end align-items-center header-actions text-white">
                <a href="/Account/Login" class="action-item">
                    <i class="bi bi-person-circle fs-4"></i>
                    <span class="d-none d-md-inline">Đăng nhập</span>
                </a>

                @{ 
                    // Show server-side cart badge from session
                    var _cart = Context.Session.GetString("Cart");
                    int _qty = 0;
                    if (!string.IsNullOrEmpty(_cart))
                    {
                        try {
                            var _list = System.Text.Json.JsonSerializer.Deserialize<List<TechStoreWeb.Models.CartItem>>(_cart);
                            if (_list != null) _qty = _list.Sum(i=>i.Qty);
                        } catch {}
                    }
                }

                <a href="/Cart/Index" class="action-item position-relative">
                    <i class="bi bi-cart3 fs-4"></i>
                    <span class="d-none d-md-inline">Giỏ hàng</span>
                    <span class="badge bg-danger rounded-pill ms-1 cart-badge">@_qty</span>
                </a>
            </div>
        </div>
    </header>

    <div class="container my-4" style="min-height: 75vh;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="py-3 mt-auto text-center">
        <div class="container">
            <span>&copy; 2026 - TechStore - Bản thiết kế hệ thống bán lẻ điện thoại thông minh</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>


    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>