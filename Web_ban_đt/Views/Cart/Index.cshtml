@model List<TechStoreWeb.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
    var discount = ViewBag.Discount ?? 0m;
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        .cart-wrapper {
            width: 100%;
            max-width: 1200px;
            margin: 40px auto 80px auto;
            padding: 0 20px;
            font-family: 'Outfit', sans-serif;
        }
        
        .cart-header {
            display: flex;
            align-items: center;
            margin-bottom: 30px;
        }
        
        .cart-icon-box {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 20px;
            box-shadow: 0 8px 20px rgba(67, 97, 238, 0.25);
            color: white;
            font-size: 28px;
        }
        
        .cart-title {
            font-weight: 800;
            color: #1e293b;
            margin: 0;
            font-size: 32px;
            letter-spacing: -0.5px;
        }

        .cart-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 32px;
            align-items: start;
        }

        .cart-card {
            background-color: #ffffff;
            border-radius: 24px;
            padding: 30px;
            box-shadow: 0 10px 40px -10px rgba(0,0,0,0.05);
            border: 1px solid rgba(0,0,0,0.02);
        }
        
        .table-cart {
            width: 100%;
            border-collapse: collapse;
        }
        
        .table-cart th {
            font-weight: 600;
            color: #64748b;
            border-bottom: 1px dashed #e2e8f0;
            padding-bottom: 16px;
            font-size: 15px;
            text-align: left;
        }
        
        .table-cart th.text-center, .table-cart td.text-center { text-align: center; }
        .table-cart th.text-right, .table-cart td.text-right { text-align: right; }
        
        .table-cart td {
            vertical-align: middle;
            border-bottom: 1px dashed #f1f5f9;
            padding: 24px 0;
            color: #1e293b;
            font-size: 16px;
        }
        
        .table-cart tr:last-child td {
            border-bottom: none;
        }
        
        .product-info {
            display: flex;
            align-items: center;
        }
        
        .product-info img {
            width: 80px; 
            height: 80px; 
            object-fit: contain; 
            border-radius: 12px; 
            margin-right: 20px;
            background: #f8fafc;
            border: 1px solid #f1f5f9;
            padding: 8px;
            transition: transform 0.3s;
        }
        
        .product-info:hover img {
            transform: scale(1.05);
        }
        
        .product-name {
            font-weight: 600;
            color: #1e293b;
        }

        .qty-control {
            display: inline-flex;
            align-items: center;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            background: #f8fafc;
            overflow: hidden;
        }
        .qty-btn {
            background: transparent;
            border: none;
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: #475569;
            font-size: 20px;
            transition: all 0.2s;
        }
        .qty-btn:hover:not(:disabled) {
            background: #e0e7ff;
            color: #4361ee;
        }
        .qty-input {
            width: 40px;
            text-align: center;
            font-weight: 600;
            color: #1e293b;
        }
        
        .checkout-btn {
            background: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%);
            color: #ffffff;
            border: none;
            padding: 18px 24px;
            border-radius: 16px;
            font-weight: 700;
            transition: all 0.3s ease;
            text-align: center;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            width: 100%;
            font-size: 16px;
            cursor: pointer;
            box-shadow: 0 8px 20px rgba(67, 97, 238, 0.25);
            text-decoration: none;
        }
        .checkout-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 25px rgba(67, 97, 238, 0.35);
            color: white;
        }
        
        .cart-summary-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
            color: #64748b;
            font-size: 16px;
            font-weight: 500;
        }
        .cart-summary-item.total {
            color: #0f172a;
            font-weight: 800;
            font-size: 20px;
            margin-bottom: 30px;
            padding-top: 20px;
            border-top: 2px dashed #e2e8f0;
        }
        
        .voucher-input-group {
            display: flex;
            margin: 24px 0 30px 0;
            background: #f8fafc;
            border-radius: 12px;
            padding: 6px;
            border: 1px solid #e2e8f0;
        }
        .voucher-input-group input {
            flex: 1;
            padding: 12px 16px;
            border: none;
            background: transparent;
            outline: none;
            font-family: inherit;
            font-size: 15px;
        }
        .voucher-input-group button {
            padding: 10px 24px;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            color: #4361ee;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            transition: all 0.2s;
            box-shadow: 0 2px 6px rgba(0,0,0,0.02);
        }
        .voucher-input-group button:hover {
            background: #4361ee;
            color: white;
            border-color: #4361ee;
        }

        .custom-checkbox {
            width: 22px;
            height: 22px;
            cursor: pointer;
            margin: 0;
            accent-color: #4361ee;
        }
        
        .btn-remove {
            background: #fee2e2;
            border: none;
            color: #ef4444;
            cursor: pointer;
            font-size: 18px;
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }
        .btn-remove:hover {
            background: #ef4444;
            color: white;
            transform: scale(1.05);
        }

        .empty-cart {
            text-align: center;
            padding: 80px 0;
        }
        .empty-cart-icon {
            width: 120px;
            height: 120px;
            background: #f8fafc;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px auto;
            color: #cbd5e1;
            font-size: 56px;
        }
        .empty-cart-title {
            font-size: 24px;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 12px;
        }
        .empty-cart-desc {
            color: #64748b;
            margin-bottom: 32px;
        }
        .btn-shopping {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 16px 32px;
            background: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%);
            color: #fff;
            border-radius: 16px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s;
            box-shadow: 0 8px 20px rgba(67, 97, 238, 0.25);
        }
        .btn-shopping:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 25px rgba(67, 97, 238, 0.35);
            color: white;
        }
        
        form { margin: 0; }
        
        @@media (max-width: 992px) {
            .cart-grid { grid-template-columns: 1fr; }
        }
    </style>
}

<div class="cart-wrapper">
    <div class="cart-header">
        <div class="cart-icon-box">
            <i class="bi bi-cart3"></i>
        </div>
        <h3 class="cart-title">Giỏ hàng của bạn</h3>
    </div>

    <div class="cart-grid">
        <div class="cart-card">
            <table class="table-cart">
            <thead>
                <tr>
                    <th style="width:50px"></th>
                    <th>Sản phẩm</th>
                    <th style="width:140px">Đơn giá</th>
                    <th style="width:130px" class="text-center">Số lượng</th>
                    <th style="width:140px" class="text-right">Thành tiền</th>
                    <th style="width:60px"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-cart">
                                <div class="empty-cart-icon">
                                    <i class="bi bi-cart-x"></i>
                                </div>
                                <div class="empty-cart-title">Giỏ hàng trống</div>
                                <div class="empty-cart-desc">Không có sản phẩm nào trong giỏ hàng của bạn.</div>
                                <a href="/" class="btn-shopping"><i class="bi bi-shop"></i> Khám phá sản phẩm ngay</a>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">
                                <form asp-controller="Cart" asp-action="ToggleSelect" method="post" style="display:flex; justify-content:center;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="selected" class="selected-input" value="@item.Selected.ToString().ToLower()" />
                                    <input type="checkbox" class="custom-checkbox" @(item.Selected? "checked":"") onchange="this.form.querySelector('.selected-input').value=this.checked; this.form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));" />
                                </form>
                            </td>
                            <td>
                                <div class="product-info">
                                    <img src="@item.Img" alt="@item.Name"> 
                                    <span class="product-name">@item.Name</span>
                                </div>
                            </td>
                            <td style="font-weight: 500;">@item.Price.ToString("N0")đ</td>
                            <td class="text-center">
                                <div class="qty-control">
                                    <form asp-controller="Cart" asp-action="UpdateQty" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="qty" value="@(item.Qty - 1)" />
                                        <button type="submit" class="qty-btn" @(item.Qty <= 1 ? "disabled" : "")><i class="bi bi-dash"></i></button>
                                    </form>
                                    <span class="qty-input">@item.Qty</span>
                                    <form asp-controller="Cart" asp-action="UpdateQty" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="qty" value="@(item.Qty + 1)" />
                                        <button type="submit" class="qty-btn"><i class="bi bi-plus"></i></button>
                                    </form>
                                </div>
                            </td>
                            <td class="text-right" style="color: #4361ee; font-weight: 700;">@( (item.Price * item.Qty).ToString("N0") )đ</td>
                            <td class="text-right">
                                <form asp-controller="Cart" asp-action="Remove" method="post" style="display:flex; justify-content:flex-end;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn-remove" title="Xóa sản phẩm"><i class="bi bi-trash3"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
            </table>
        </div>

        <div class="cart-card">
            <h6 style="font-weight: 800; color: #1e293b; font-size: 22px; margin-bottom: 24px; margin-top: 0; letter-spacing: -0.5px;">Tóm tắt đơn hàng</h6>
            
            @{
                var subtotal = Model?.Where(i=>i.Selected).Sum(i=>i.Price * i.Qty) ?? 0m;
                var shipping = (subtotal > 0) ? 20000m : 0m;
                var total = Math.Max(subtotal + shipping - (discount ?? 0m), 0m);
            }
            
            <div class="cart-summary-item"><span>Tạm tính</span><span>@subtotal.ToString("N0")đ</span></div>
            
            @if (discount > 0)
            {
                <div class="cart-summary-item"><span style="color: #059669;"><i class="bi bi-tag-fill me-2"></i>Mã giảm giá</span><span style="color: #059669;">- @discount?.ToString("N0")đ</span></div>
            }
            
            <div class="cart-summary-item"><span>Phí vận chuyển</span><span>@shipping.ToString("N0")đ</span></div>
            
            <form asp-controller="Cart" asp-action="ApplyVoucher" method="post" class="voucher-input-group">
                @Html.AntiForgeryToken()
                <i class="bi bi-ticket-perforated ms-3 text-muted"></i>
                <input type="text" name="code" placeholder="Nhập mã giảm giá..." required>
                <button type="submit">Áp dụng</button>
            </form>

            <div class="cart-summary-item total">
                <span>Tổng cộng</span>
                <span style="color: #ef4444; font-size: 24px;">@total.ToString("N0")đ</span>
            </div>
            
            <a href="/Cart/Checkout" class="checkout-btn">
                Tiến hành thanh toán <i class="bi bi-arrow-right-circle-fill"></i>
            </a>
            
            <div class="text-center mt-4">
                <img src="/images/Giao diện trang chủ/payment-methods.png" alt="Payment Methods" style="height: 30px; opacity: 0.5; filter: grayscale(100%);" onerror="this.style.display='none'">
                <p class="text-muted mt-2" style="font-size: 13px;"><i class="bi bi-shield-check text-success"></i> Thanh toán an toàn và bảo mật</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            function bindAjaxForms() {
                const cartForms = document.querySelectorAll('.cart-grid form');
                
                cartForms.forEach(form => {
                    form.addEventListener('submit', function(e) {
                        e.preventDefault();
                        
                        const submitBtns = this.querySelectorAll('button[type="submit"]');
                        submitBtns.forEach(btn => btn.style.opacity = '0.5');
                        
                        const formData = new FormData(this);
                        
                        fetch(this.action, {
                            method: this.method,
                            body: formData
                        })
                        .then(response => response.text())
                        .then(html => {
                            const parser = new DOMParser();
                            const doc = parser.parseFromString(html, 'text/html');
                            const newCartGrid = doc.querySelector('.cart-grid');
                            
                            if (newCartGrid) {
                                document.querySelector('.cart-grid').innerHTML = newCartGrid.innerHTML;
                                bindAjaxForms(); 
                                
                                const newBadge = doc.querySelector('.cart-badge');
                                const currentBadge = document.querySelector('.cart-badge');
                                if (newBadge && currentBadge) {
                                    currentBadge.textContent = newBadge.textContent;
                                }
                            } else {
                                window.location.reload();
                            }
                        })
                        .catch(err => {
                            console.error(err);
                            window.location.reload();
                        });
                    });
                });
            }
            
            bindAjaxForms();
        });
    </script>
}
