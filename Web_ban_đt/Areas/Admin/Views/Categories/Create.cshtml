@model TechStoreWeb.Models.Category
@{
    ViewData["Title"] = "Thêm Danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1 text-techblue fw-bold">Thêm Danh mục mới</h3>
        <p class="text-muted mb-0">Tạo danh mục mới để phân loại sản phẩm</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 10px; padding: 10px 20px; font-weight: 500;">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-0" style="border-radius: 16px;">
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-4">
                        <label asp-for="CategoryName" class="form-label fw-bold text-dark">Tên danh mục <span class="text-danger">*</span></label>
                        <input asp-for="CategoryName" class="form-control" style="border-radius: 10px; padding: 12px 15px;" placeholder="Nhập tên danh mục..." required />
                        <span asp-validation-for="CategoryName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn text-white" style="background: linear-gradient(135deg, #118ab2 0%, #06d6a0 100%); border-radius: 10px; padding: 12px; font-weight: 600; font-size: 16px;">
                            <i class="bi bi-plus-circle me-1"></i> Lưu Danh mục
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
