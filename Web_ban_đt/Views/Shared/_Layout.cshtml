@inject TechStoreWeb.Data.AppDbContext _layoutContext
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechStore</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        /* 1. Global Styles & Premium Variables */
        :root {
            --primary-color: #2563eb;
            --primary-hover: #1d4ed8;
            --bg-color: #fcfcfd;
            --surface-color: #ffffff;
            --text-main: #0a0a0a;
            --text-muted: #737373;
            
            --bezier-smooth: cubic-bezier(0.32, 0.72, 0, 1);
            --bezier-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
            --transition-speed: 0.5s;

            /* Haptic shadows & Structural depths */
            --shadow-float: 0 24px 48px -12px rgba(0, 0, 0, 0.08);
            --shadow-soft: 0 8px 30px rgba(0, 0, 0, 0.04);
            --shadow-inner: inset 0 1px 1px rgba(255, 255, 255, 0.8);
            
            --radius-md: 16px;
            --radius-lg: 24px;
            --radius-xl: 32px;
            --radius-pill: 9999px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            text-decoration: none;
            list-style: none;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            font-size: 15px;
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            letter-spacing: -0.01em;
            line-height: 1.6;
        }

        input:-webkit-autofill,
        input:-webkit-autofill:hover, 
        input:-webkit-autofill:focus, 
        input:-webkit-autofill:active {
            transition: background-color 50000s ease-in-out 0s;
            -webkit-text-fill-color: var(--text-main) !important;
        }

        .container {
            width: 100%;
            max-width: 1920px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* 2. Classic E-commerce Header */
        .site-header {
            background-color: var(--primary-color);
            background: linear-gradient(90deg, #2563eb, #1d4ed8);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            width: 100%;
        }

        .site-header .container {
            display: flex;
            align-items: center;
            height: 64px;
            gap: 16px;
        }

        .header-logo {
            font-size: 22px;
            font-weight: 800;
            letter-spacing: -0.04em;
            color: #ffffff;
            text-decoration: none;
            display: flex;
            align-items: center;
            flex-shrink: 0;
        }
        .header-logo:hover { color: #ffffff; opacity: 0.9; }

        .search-bar-container {
            display: flex;
            flex: 1;
            border-radius: 8px;
            background-color: #ffffff;
            height: 38px;
            position: relative;
            align-items: center;
            overflow: hidden;
            margin: 0 16px;
        }
        .search-bar-container input {
            flex: 1;
            border: none;
            padding: 0 8px;
            outline: none;
            font-size: 13px;
            color: var(--text-main);
            background: transparent;
        }
        .search-bar-container button {
            background: transparent;
            border: none;
            padding: 0 12px;
            cursor: pointer;
            color: #777;
            font-size: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .header-actions {
            display: flex;
            gap: 12px;
            align-items: center;
            flex-shrink: 0;
        }

        .action-btn {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 8px;
            padding: 8px 12px;
            display: flex;
            align-items: center;
            gap: 8px;
            color: white;
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            transition: 0.2s;
            position: relative;
        }
        .action-btn:hover {
            background: rgba(255, 255, 255, 0.25);
            color: white;
        }
        .action-btn i {
            font-size: 16px;
            color: white;
        }

        .cart-badge {
            background: #f97316;
            color: white;
            border-radius: var(--radius-pill);
            padding: 0 4px;
            font-size: 10px;
            font-weight: 700;
            position: absolute;
            top: -6px;
            right: -6px;
            height: 16px;
            min-width: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 2px solid var(--primary-color);
        }

        /* Header Category Menu */
        .header-menu-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            flex-shrink: 0;
        }
        .header-menu-btn {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 8px;
            padding: 8px 12px;
            display: flex;
            align-items: center;
            gap: 6px;
            color: white;
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            transition: 0.2s;
        }
        .header-menu-btn:hover { background: rgba(255, 255, 255, 0.25); }
        .header-menu-dropdown {
            position: absolute;
            top: 100%;
            left: 0;
            width: 260px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.15);
            opacity: 0;
            visibility: hidden;
            transition: all 0.2s var(--bezier-smooth);
            z-index: 1001;
            margin-top: 16px;
            padding: 8px 0;
        }
        .header-menu-wrapper:hover .header-menu-dropdown {
            opacity: 1;
            visibility: visible;
            margin-top: 8px;
        }
        .header-menu-dropdown ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; }
        .header-menu-dropdown li a {
            display: flex;
            align-items: center;
            padding: 10px 16px;
            color: var(--text-main);
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: 0.2s;
        }
        .header-menu-dropdown li a:hover {
            background: rgba(37, 99, 235, 0.05);
            color: var(--primary-color);
        }
        .header-menu-dropdown li a i:first-child {
            font-size: 16px;
            margin-right: 12px;
            width: 20px;
            text-align: center;
            color: var(--text-muted);
        }
        .header-menu-dropdown li a:hover i:first-child {
            color: var(--primary-color);
        }
        .header-menu-dropdown li a i.bi-chevron-right {
            margin-left: auto;
            font-size: 11px;
            color: var(--text-muted);
        }

        /* 3. Main Layout Grid */
        .main-layout {
            padding: 24px 0 100px 0;
        }

        /* ---------- Footer ---------- */
        .site-footer {
            margin-top: 48px;
            background: #f4f6fb;
            border-top: 1px solid rgba(37, 99, 235, 0.12);
            color: var(--text-main);
            font-size: 14px;
        }

        .footer-main {
            display: grid;
            grid-template-columns: 1.15fr 1fr 1fr 1fr;
            gap: 40px;
            padding: 48px 0 40px 0;
        }

        .footer-col h4 {
            font-size: 15px;
            font-weight: 700;
            margin: 0 0 16px 0;
            color: var(--text-main);
        }

        .footer-col h4:not(:first-child) { margin-top: 28px; }

        .footer-links { list-style: none; margin: 0; padding: 0; }
        .footer-links li { margin-bottom: 10px; }
        .footer-links a {
            color: #4b5563;
            text-decoration: none;
            transition: color 0.15s;
        }
        .footer-links a:hover { color: var(--primary-color); text-decoration: underline; }

        .footer-hotline { margin-bottom: 10px; color: #4b5563; line-height: 1.6; }
        .footer-hotline strong { color: var(--primary-color); font-weight: 700; }

        .footer-pay {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        .footer-pay span {
            background: #fff;
            border: 1px solid rgba(0,0,0,0.08);
            border-radius: 6px;
            padding: 6px 10px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.02em;
            color: #374151;
        }

        .footer-social { display: flex; flex-wrap: wrap; gap: 10px; }
        .footer-social a {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--primary-color);
            color: #fff;
            font-size: 17px;
            text-decoration: none;
            transition: transform 0.15s, background 0.15s;
        }
        .footer-social a:hover { transform: translateY(-2px); background: var(--primary-hover); }

        /* Đăng ký nhận tin */
        .footer-subscribe {
            background: #fff;
            border: 1px solid rgba(37, 99, 235, 0.18);
            border-radius: 10px;
            padding: 16px;
            margin-top: 8px;
        }
        .footer-subscribe p {
            margin: 0 0 12px 0;
            font-size: 12px;
            color: var(--text-muted);
            line-height: 1.5;
        }
        .footer-subscribe input {
            width: 100%;
            padding: 9px 12px;
            border: 1px solid rgba(0,0,0,0.12);
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 10px;
            font-family: inherit;
        }
        .footer-subscribe input:focus {
            outline: none;
            border-color: var(--primary-color);
        }
        .footer-subscribe button {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 8px;
            background: var(--primary-color);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            font-family: inherit;
            transition: background 0.15s;
        }
        .footer-subscribe button:hover { background: var(--primary-hover); }
        .footer-subscribe .form-note {
            margin: 10px 0 0 0;
            font-size: 12px;
            color: var(--primary-color);
            display: none;
        }

        /* Dải từ khoá */
        .footer-tags {
            border-top: 1px solid rgba(0,0,0,0.07);
            padding: 20px 0;
            display: flex;
            flex-wrap: wrap;
            gap: 8px 0;
            font-size: 13px;
        }
        .footer-tags a {
            color: #4b5563;
            text-decoration: none;
            padding: 0 12px;
            border-right: 1px solid rgba(0,0,0,0.15);
            line-height: 1.2;
        }
        .footer-tags a:first-child { padding-left: 0; }
        .footer-tags a:last-child { border-right: none; }
        .footer-tags a:hover { color: var(--primary-color); }

        /* Dòng pháp lý */
        .footer-legal {
            background: #0b2a6f;
            color: rgba(255,255,255,0.72);
            font-size: 12.5px;
            line-height: 1.7;
            text-align: center;
            padding: 20px 24px;
        }
        .footer-legal strong { color: #fff; font-weight: 600; }

        @@media (max-width: 1024px) {
            .site-header .container { gap: 16px; padding: 0 16px; }
            .search-bar-container { display: none; }
            .footer-main { grid-template-columns: 1fr 1fr; gap: 32px; }
        }

        @@media (max-width: 640px) {
            .footer-main { grid-template-columns: 1fr; padding: 32px 0; }
            .footer-tags { justify-content: center; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="site-header">
        <div class="container">
            <a href="/" class="header-logo" aria-label="Home">
                TECHBLUE
            </a>

            <div class="header-menu-wrapper">
                <div class="header-menu-btn">
                    <i class="bi bi-grid-fill"></i>
                    <span>Danh mục</span>
                    <i class="bi bi-chevron-down" style="font-size: 10px; margin-left: 2px;"></i>
                </div>
                <div class="header-menu-dropdown">
                    <ul>
                        @{
                            var layoutCategories = _layoutContext.Categories.ToList();
                            if (layoutCategories.Any())
                            {
                                foreach (var cat in layoutCategories)
                                {
                                    <li><a href="/Home/Index?categoryId=@cat.CategoryId"><i class="bi bi-phone"></i> @cat.CategoryName <i class="bi bi-chevron-right"></i></a></li>
                                }
                            }
                            else
                            {
                                <li><a href="#"><i class="bi bi-phone"></i> Đang cập nhật... <i class="bi bi-chevron-right"></i></a></li>
                            }
                        }
                    </ul>
                </div>
            </div>

            <form action="/Home/Index" method="get" class="search-bar-container">
                <button type="submit" aria-label="Tìm kiếm"><i class="bi bi-search"></i></button>
                <input type="text" name="searchString" placeholder="Bạn muốn mua gì hôm nay?" value="@((string)ViewData["SearchString"] ?? Context.Request.Query["searchString"])" />
            </form>

            <div class="header-actions">
                <a href="/Cart/Index" class="action-btn">
                    <i class="bi bi-bag"></i>
                    <span>Giỏ hàng</span>
                    @{ 
                        var _cart = Context.Session.GetString("Cart");
                        int _qty = 0;
                        if (!string.IsNullOrEmpty(_cart))
                        {
                            try {
                                var _list = System.Text.Json.JsonSerializer.Deserialize<List<TechStoreWeb.Models.CartItem>>(_cart);
                                if (_list != null) _qty = _list.Sum(i=>i.Qty);
                            } catch {}
                        }
                    }
                    <span class="cart-badge">@_qty</span>
                </a>
                @{
                    var username = Context.Session.GetString("Username");
                    var role = Context.Session.GetString("Role");
                }
                @if (string.IsNullOrEmpty(username))
                {
                    var currentUrl = Context.Request.Path + Context.Request.QueryString;
                    <a href="/Account/Login?returnUrl=@System.Net.WebUtility.UrlEncode(currentUrl)" class="action-btn">
                        <i class="bi bi-person-circle"></i>
                        <span>Đăng nhập</span>
                    </a>
                }
                else
                {
                    <a href="/Account/Profile" class="action-btn">
                        <i class="bi bi-person-circle"></i>
                        <span>@username</span>
                    </a>
                    @if (role == "Admin" || role == "Employee")
                    {
                        <a href="/Admin/Reports" class="action-btn" style="background: rgba(239, 68, 68, 0.2); color: #fca5a5;">
                            <i class="bi bi-shield-lock"></i>
                            <span>Quản trị</span>
                        </a>
                    }
                }
            </div>
        </div>
    </header>

    @RenderBody()

    @* TODO: thay các mục [trong ngoặc vuông] bằng thông tin thật của cửa hàng *@
    <footer class="site-footer">
        <div class="container">
            <div class="footer-main">

                <div class="footer-col">
                    <h4>Tổng đài hỗ trợ</h4>
                    <div class="footer-hotline">
                        Mua hàng &amp; bảo hành <strong>[1900 xxxx]</strong><br>
                        <span style="color:var(--text-muted); font-size:13px;">7h30 – 22h00 tất cả các ngày</span>
                    </div>
                    <div class="footer-hotline">
                        Khiếu nại &amp; góp ý <strong>[1900 xxxx]</strong><br>
                        <span style="color:var(--text-muted); font-size:13px;">8h00 – 21h30</span>
                    </div>

                    <h4>Phương thức thanh toán</h4>
                    <div class="footer-pay">
                        <span>COD</span>
                        <span>VNPAY</span>
                        <span>MOMO</span>
                        <span>ZALOPAY</span>
                        <span>THẺ ATM</span>
                        <span>TRẢ GÓP 0%</span>
                    </div>
                </div>

                <div class="footer-col">
                    <h4>Thông tin và chính sách</h4>
                    <ul class="footer-links">
                        <li><a href="/Cart">Mua hàng và thanh toán online</a></li>
                        <li><a href="#">Chính sách trả góp</a></li>
                        <li><a href="#">Chính sách giao hàng</a></li>
                        <li><a href="#">Chính sách đổi trả</a></li>
                        <li><a href="#">Chính sách bảo hành</a></li>
                        <li><a href="#">Tra cứu thông tin bảo hành</a></li>
                        <li><a href="#">Tra cứu hoá đơn điện tử</a></li>
                        <li><a href="/Home/Privacy">Chính sách bảo mật thông tin</a></li>
                    </ul>
                </div>

                <div class="footer-col">
                    <h4>Dịch vụ và hỗ trợ</h4>
                    <ul class="footer-links">
                        <li><a href="/Account/Orders">Tra cứu đơn hàng</a></li>
                        <li><a href="/Account/Profile">Tài khoản của tôi</a></li>
                        <li><a href="#">Khách hàng doanh nghiệp</a></li>
                        <li><a href="#">Ưu đãi thanh toán</a></li>
                        <li><a href="#">Quy chế hoạt động</a></li>
                        <li><a href="#">Liên hệ hợp tác kinh doanh</a></li>
                        <li><a href="#">Tuyển dụng</a></li>
                        <li><a href="#">Dịch vụ bảo hành mở rộng</a></li>
                    </ul>
                </div>

                <div class="footer-col">
                    <h4>Kết nối với TECHBLUE</h4>
                    <div class="footer-social">
                        <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" aria-label="TikTok"><i class="bi bi-tiktok"></i></a>
                        <a href="#" aria-label="Zalo"><i class="bi bi-chat-dots-fill"></i></a>
                    </div>

                    <h4>Đăng ký nhận khuyến mãi</h4>
                    <div class="footer-subscribe">
                        <p>Nhận thông tin ưu đãi và sản phẩm mới sớm nhất từ TECHBLUE.</p>
                        <form id="footerSubscribeForm" onsubmit="return false;">
                            <input type="email" id="footerSubscribeEmail" placeholder="Nhập email của bạn" aria-label="Email nhận tin" required>
                            <button type="submit">ĐĂNG KÝ NGAY</button>
                            <p class="form-note" id="footerSubscribeNote">Tính năng đang được hoàn thiện, bạn quay lại sau nhé!</p>
                        </form>
                    </div>
                </div>

            </div>

            <div class="footer-tags">
                <a href="/Home/Index">Điện thoại</a>
                <a href="/Home/Index">iPhone</a>
                <a href="/Home/Index">Samsung</a>
                <a href="/Home/Index">Xiaomi</a>
                <a href="/Home/Index">OPPO</a>
                <a href="/Home/Index">Honor</a>
                <a href="/Home/Index">Huawei</a>
                <a href="/Home/Index">Nokia</a>
                <a href="/Home/Index">Tecno</a>
                <a href="/Home/Index">Phụ kiện</a>
                <a href="/Home/Index">Trả góp 0%</a>
                <a href="/Home/Index">Hàng mới về</a>
            </div>
        </div>

        <div class="footer-legal">
            <strong>[Tên công ty đầy đủ]</strong> — GPĐKKD: [số giấy phép] cấp tại [nơi cấp].<br>
            Địa chỉ: [địa chỉ trụ sở] — Điện thoại: [số điện thoại] — Email: [email liên hệ]<br>
            © @DateTime.Now.Year TECHBLUE. Bảo lưu mọi quyền.
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Form đăng ký nhận tin chưa có backend: báo rõ cho khách thay vì im lặng không làm gì.
        (function () {
            const form = document.getElementById('footerSubscribeForm');
            if (!form) return;
            form.addEventListener('submit', function () {
                const email = document.getElementById('footerSubscribeEmail');
                if (!email.value.trim()) return;
                document.getElementById('footerSubscribeNote').style.display = 'block';
            });
        })();
    </script>

    <partial name="_ChatbotWidget" />
</body>
</html>
