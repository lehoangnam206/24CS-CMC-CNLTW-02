@model TechStoreWeb.Models.User
@{
    ViewData["Title"] = "Đăng ký";
}

@section Styles {
    <style>
        .auth-wrapper {
            background-color: var(--bg-color);
            min-height: calc(100vh - 72px);
            width: 100vw;
            position: relative;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            margin: 0;
        }
        
        .auth-card {
            display: flex;
            background: var(--surface-color);
            border-radius: var(--radius-xl);
            padding: 8px;
            box-shadow: var(--shadow-float);
            width: 100%;
            max-width: 1100px;
            min-height: 640px;
            border: 1px solid rgba(0,0,0,0.03);
        }
        
        .auth-left {
            flex: 1.2;
            background: url('/images/Giao diện trang chủ/Đăng kí.png') center/cover no-repeat;
            border-radius: calc(var(--radius-xl) - 8px);
            position: relative;
            overflow: hidden;
            box-shadow: inset 0 0 0 1px rgba(255,255,255,0.2);
        }
        
        .auth-right {
            flex: 1;
            padding: 48px 64px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background-color: var(--surface-color);
        }
        
        .auth-title {
            font-size: 36px;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 12px;
            letter-spacing: -0.04em;
        }

        .auth-subtitle {
            color: var(--text-muted);
            font-size: 15px;
            margin-bottom: 40px;
            font-weight: 500;
        }
        
        .input-group-custom {
            display: flex;
            align-items: center;
            background-color: var(--bg-color);
            border: 1px solid rgba(0,0,0,0.05);
            border-radius: var(--radius-lg);
            padding: 2px 24px;
            margin-bottom: 16px;
            transition: all 0.3s var(--bezier-smooth);
        }
        
        .input-group-custom:focus-within {
            background-color: var(--surface-color);
            border-color: var(--primary-color);
            box-shadow: 0 4px 16px rgba(37, 99, 235, 0.1);
            transform: translateY(-2px);
        }

        .input-group-custom i {
            font-size: 18px;
            color: rgba(0,0,0,0.2);
            margin-right: 16px;
            transition: color 0.3s;
        }

        .input-group-custom:focus-within i { color: var(--primary-color); }
        
        .form-control-custom {
            flex: 1;
            border: none;
            background: transparent;
            padding: 14px 0;
            font-size: 15px;
            font-weight: 500;
            color: var(--text-main);
            outline: none;
            font-family: inherit;
        }
        
        .form-control-custom::placeholder { color: var(--text-muted); font-weight: 400; }
        
        .btn-register {
            background: var(--primary-color);
            color: var(--surface-color);
            border: none;
            border-radius: var(--radius-pill);
            padding: 18px;
            width: 100%;
            font-weight: 700;
            font-size: 16px;
            transition: all 0.4s var(--bezier-smooth);
            margin-top: 16px;
            margin-bottom: 24px;
            cursor: pointer;
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
            font-family: inherit;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }
        
        .btn-register:hover {
            transform: translateY(-4px) scale(0.98);
            box-shadow: 0 16px 32px rgba(0,0,0,0.2);
            background: var(--primary-color);
        }
        
        .social-divider {
            display: flex;
            align-items: center;
            text-align: center;
            color: var(--text-muted);
            font-size: 13px;
            margin-bottom: 24px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        .social-divider::before, .social-divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }
        
        .social-divider span { padding: 0 16px; }
        
        .social-icons {
            display: flex;
            justify-content: center;
            gap: 16px;
        }
        
        .social-icons a {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 48px;
            height: 48px;
            font-size: 20px;
            border-radius: 50%;
            border: 1px solid rgba(0,0,0,0.05);
            background: var(--bg-color);
            transition: all 0.3s var(--bezier-smooth);
            text-decoration: none;
            color: var(--text-main);
        }
        
        .social-icons a:hover {
            background: var(--surface-color);
            box-shadow: var(--shadow-soft);
            transform: translateY(-4px) scale(1.1);
        }
        
        .social-icons a.google:hover { color: #ea4335; border-color: #ea4335; }
        .social-icons a.facebook:hover { color: #1877f2; border-color: #1877f2; }
        
        .login-link {
            text-align: center;
            margin-top: 32px;
            font-size: 15px;
            color: var(--text-muted);
            font-weight: 500;
        }

        .login-link a {
            color: var(--text-main);
            font-weight: 700;
            text-decoration: none;
            margin-left: 4px;
            transition: color 0.3s;
        }

        .login-link a:hover { color: var(--primary-color); }

        @@media (max-width: 768px) {
            .auth-card { flex-direction: column; }
            .auth-left { min-height: 250px; border-radius: calc(var(--radius-xl) - 8px) calc(var(--radius-xl) - 8px) 0 0; }
            .auth-right { padding: 40px 24px; }
        }
        footer { display: none !important; }
    </style>
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-left"></div>

        <div class="auth-right">
            <h3 class="auth-title">Tạo Tài Khoản</h3>
            <p class="auth-subtitle">Điền đầy đủ thông tin để bắt đầu</p>
            
            <form asp-action="Register" method="post">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <div asp-validation-summary="All" style="font-size: 14px; padding: 16px; background: rgba(239, 68, 68, 0.1); color: #ef4444; border-radius: var(--radius-lg); margin-bottom: 24px; font-weight: 500;"></div>

                <div class="input-group-custom">
                    <i class="bi bi-person"></i>
                    <input asp-for="FullName" class="form-control-custom" placeholder="Họ và tên" required />
                </div>

                <div class="input-group-custom">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="Email" type="email" class="form-control-custom" placeholder="Địa chỉ email" required />
                </div>
                
                <div class="input-group-custom">
                    <i class="bi bi-at"></i>
                    <input asp-for="Username" class="form-control-custom" placeholder="Tên đăng nhập" required />
                </div>
                
                <div class="input-group-custom">
                    <i class="bi bi-telephone"></i>
                    <input asp-for="PhoneNumber" class="form-control-custom" placeholder="Số điện thoại" required />
                </div>

                <div class="input-group-custom">
                    <i class="bi bi-lock"></i>
                    <input asp-for="Password" type="password" class="form-control-custom" placeholder="Mật khẩu" required />
                </div>

                <div class="input-group-custom">
                    <i class="bi bi-shield-lock"></i>
                    <input type="password" name="ConfirmPassword" class="form-control-custom" placeholder="Xác nhận mật khẩu" required />
                </div>

                <button type="submit" class="btn-register">Tạo tài khoản <i class="bi bi-arrow-right"></i></button>
                
                <div class="social-divider">
                    <span>Hoặc đăng ký bằng</span>
                </div>
                
                <div class="social-icons">
                    <a href="/Account/ExternalLogin?provider=Google&returnUrl=@(ViewData["ReturnUrl"] ?? "/")" class="google" title="Đăng ký bằng Google"><i class="bi bi-google"></i></a>
                    <a href="/Account/ExternalLogin?provider=Facebook&returnUrl=@(ViewData["ReturnUrl"] ?? "/")" class="facebook" title="Đăng ký bằng Facebook"><i class="bi bi-facebook"></i></a>
                </div>

                <div class="login-link">
                    Đã có tài khoản? <a href="/Account/Login?returnUrl=@ViewData["ReturnUrl"]">Đăng nhập</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}