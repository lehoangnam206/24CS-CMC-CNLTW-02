@model TechStoreWeb.Models.User
@{
    ViewData["Title"] = "Chi tiết Người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1 text-techblue fw-bold">Chi tiết Người dùng #@Model.UserId</h3>
        <p class="text-muted mb-0">Xem thông tin tài khoản và hoạt động</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius: 10px; padding: 10px 20px; font-weight: 500;">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 mb-4" style="border-radius: 16px; overflow: hidden;">
            <div class="card-body text-center p-4">
                <div style="width: 100px; height: 100px; border-radius: 50%; background: linear-gradient(135deg, #118ab2 0%, #06d6a0 100%); color: white; display: flex; align-items: center; justify-content: center; font-size: 40px; font-weight: bold; margin: 0 auto 20px; box-shadow: 0 4px 20px rgba(17, 138, 178, 0.3);">
                    @(Model.Username.Substring(0, 1).ToUpper())
                </div>
                <h4 class="fw-bold mb-1" style="color: #1e293b;">@Model.FullName</h4>
                <p class="text-muted mb-3">@("@")@Model.Username</p>
                
                <div class="d-flex justify-content-center gap-2 mb-3">
                    @if (Model.Role == "Admin") { 
                        <span class="badge" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 6px 16px; border-radius: 20px; font-size: 14px;">Admin</span> 
                    } else { 
                        <span class="badge" style="background: #f1f5f9; color: #64748b; padding: 6px 16px; border-radius: 20px; font-size: 14px;">Khách hàng</span> 
                    }

                    @if (Model.IsLocked) { 
                        <span class="badge" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; padding: 6px 16px; border-radius: 20px; font-size: 14px;"><i class="bi bi-lock-fill me-1"></i>Bị khóa</span> 
                    } else { 
                        <span class="badge" style="background: rgba(16, 185, 129, 0.1); color: #10b981; padding: 6px 16px; border-radius: 20px; font-size: 14px;"><i class="bi bi-unlock-fill me-1"></i>Hoạt động</span> 
                    }
                </div>
                
                @if (Model.Role != "Admin")
                {
                    <form asp-action="ToggleLock" asp-route-id="@Model.UserId" method="post" class="mt-4">
                        @if (Model.IsLocked) {
                            <button type="submit" class="btn text-success w-100" style="background: rgba(16, 185, 129, 0.1); border-radius: 10px; padding: 12px; font-weight: 600;">
                                <i class="bi bi-unlock-fill me-2"></i> Mở khóa tài khoản
                            </button>
                        } else {
                            <button type="submit" class="btn text-warning w-100" style="background: rgba(245, 158, 11, 0.1); border-radius: 10px; padding: 12px; font-weight: 600;" onclick="return confirm('Bạn có chắc chắn muốn khóa tài khoản này?');">
                                <i class="bi bi-lock-fill me-2"></i> Khóa tài khoản
                            </button>
                        }
                    </form>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card shadow-sm border-0" style="border-radius: 16px;">
            <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                <h5 class="fw-bold" style="color: #1e293b;"><i class="bi bi-person-lines-fill text-primary me-2"></i> Thông tin liên hệ</h5>
            </div>
            <div class="card-body p-4">
                <div class="row mb-4">
                    <div class="col-sm-4 text-muted fw-medium">Tên đăng nhập</div>
                    <div class="col-sm-8 fw-bold" style="color: #334155;">@Model.Username</div>
                </div>
                <hr style="border-color: #f1f5f9; margin: 15px 0;">
                <div class="row mb-4">
                    <div class="col-sm-4 text-muted fw-medium">Họ và tên</div>
                    <div class="col-sm-8 fw-bold" style="color: #334155;">@Model.FullName</div>
                </div>
                <hr style="border-color: #f1f5f9; margin: 15px 0;">
                <div class="row mb-4">
                    <div class="col-sm-4 text-muted fw-medium">Địa chỉ Email</div>
                    <div class="col-sm-8 fw-bold" style="color: #334155;">
                        <i class="bi bi-envelope text-muted me-2"></i> @Model.Email
                    </div>
                </div>
                <hr style="border-color: #f1f5f9; margin: 15px 0;">
                <div class="row">
                    <div class="col-sm-4 text-muted fw-medium">Số điện thoại</div>
                    <div class="col-sm-8 fw-bold" style="color: #334155;">
                        <i class="bi bi-telephone text-muted me-2"></i> @Model.PhoneNumber
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
