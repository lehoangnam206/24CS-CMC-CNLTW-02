@model TechStoreWeb.Models.ProductDetailViewModel
@{
    ViewData["Title"] = Model.Product.Name;
    var categories = ViewBag.Categories as IEnumerable<TechStoreWeb.Models.Category>;
}

@section Styles {
    <style>
        .detail-breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 48px;
            flex-wrap: wrap;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-weight: 600;
        }

        .detail-breadcrumb a {
            color: var(--text-muted);
            transition: color 0.3s var(--bezier-smooth);
            text-decoration: none;
        }

        .detail-breadcrumb a:hover { color: var(--primary-color); }
        .detail-breadcrumb .separator { color: rgba(0,0,0,0.2); }
        .detail-breadcrumb .current { color: var(--text-main); }

        .detail-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 64px;
            align-items: start;
        }

        /* LEFT COLUMN - Image Presentation */
        .detail-image-card {
            background: #f8fafc;
            border-radius: var(--radius-xl);
            padding: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: sticky;
            top: 130px;
            min-height: 480px;
            mix-blend-mode: multiply;
        }

        .detail-image-card img {
            max-width: 100%;
            max-height: 480px;
            object-fit: contain;
            transition: transform 0.6s var(--bezier-bounce);
            filter: drop-shadow(0 20px 40px rgba(0,0,0,0.1));
        }

        .detail-image-card:hover img { transform: scale(1.05) translateY(-10px); }

        /* RIGHT COLUMN - Info & Purchase */
        .detail-right-col {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .detail-product-name {
            font-size: 28px;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 8px;
            line-height: 1.2;
            letter-spacing: -0.03em;
        }

        .detail-product-brand {
            font-size: 14px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 500;
        }

        .detail-product-brand span {
            background: rgba(37, 99, 235, 0.1);
            color: var(--primary-color);
            padding: 4px 12px;
            border-radius: var(--radius-pill);
            font-weight: 700;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .detail-status-row {
            display: flex;
            align-items: center;
            gap: 16px;
            padding-bottom: 12px;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .detail-status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 16px;
            border-radius: var(--radius-pill);
            font-size: 13px;
            font-weight: 700;
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
        }

        .detail-price-section { margin-bottom: 16px; }

        .detail-price {
            font-size: 28px;
            font-weight: 800;
            color: #ef4444;
            letter-spacing: -0.02em;
            line-height: 1;
            margin-bottom: 8px;
        }

        /* Variants */
        .variant-section { margin-bottom: 16px; }
        
        .variant-label {
            font-size: 13px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 8px;
            display: block;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .variant-options { display: flex; gap: 12px; flex-wrap: wrap; }

        .variant-btn {
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: var(--radius-md);
            padding: 8px 16px;
            background: transparent;
            cursor: pointer;
            text-align: left;
            transition: all 0.3s var(--bezier-smooth);
            min-width: 120px;
            position: relative;
        }

        .variant-btn:hover { border-color: rgba(0,0,0,0.3); transform: translateY(-2px); }

        .variant-btn.active {
            border-color: var(--primary-color);
            background: var(--surface-color);
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.15);
        }

        .variant-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 4px;
        }

        .variant-price { font-size: 13px; color: var(--text-muted); font-weight: 500; }

        /* Quantity & Actions */
        .detail-quantity-section {
            display: flex;
            align-items: center;
            gap: 24px;
            margin-bottom: 20px;
        }

        .detail-quantity-label {
            font-size: 13px;
            font-weight: 700;
            color: var(--text-main);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .detail-quantity-control {
            display: flex;
            align-items: center;
            border-radius: var(--radius-pill);
            overflow: hidden;
            background: rgba(0,0,0,0.03);
            padding: 4px;
        }

        .detail-quantity-control button {
            width: 40px;
            height: 40px;
            border: none;
            background: transparent;
            color: var(--text-main);
            font-size: 18px;
            cursor: pointer;
            border-radius: 50%;
            transition: all 0.3s var(--bezier-smooth);
        }

        .detail-quantity-control button:hover { background: var(--surface-color); box-shadow: var(--shadow-soft); }

        .detail-quantity-control input {
            width: 48px;
            height: 40px;
            border: none;
            text-align: center;
            font-size: 16px;
            font-weight: 700;
            color: var(--text-main);
            background: transparent;
            outline: none;
        }

        .detail-actions { display: flex; gap: 16px; }

        .detail-btn-buy {
            flex: 1;
            padding: 12px 24px;
            background: var(--primary-color);
            color: var(--surface-color);
            border: none;
            border-radius: var(--radius-pill);
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            transition: all 0.4s var(--bezier-smooth);
        }

        .detail-btn-buy:hover {
            background: var(--primary-color);
            transform: scale(0.98);
            box-shadow: 0 10px 25px rgba(37, 99, 235, 0.3);
        }

        .detail-btn-cart {
            width: 48px;
            height: 48px;
            background: rgba(0,0,0,0.03);
            color: var(--text-main);
            border: none;
            border-radius: 50%;
            font-size: 18px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.4s var(--bezier-smooth);
        }

        .detail-btn-cart:hover {
            background: var(--surface-color);
            color: var(--primary-color);
            box-shadow: var(--shadow-soft);
            transform: scale(1.1);
        }

        /* Specs Table */
        .detail-specs-card {
            background: var(--surface-color);
            border-radius: var(--radius-xl);
            padding: 6px;
            box-shadow: var(--shadow-soft);
            border: 1px solid rgba(0,0,0,0.03);
            grid-column: 1 / -1;
            margin-top: 32px;
        }
        
        .detail-specs-inner {
            background: var(--bg-color);
            border-radius: calc(var(--radius-xl) - 6px);
            padding: 32px;
        }

        .detail-specs-header {
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }
        .detail-specs-header h2 {
            font-size: 20px;
            font-weight: 800;
            letter-spacing: -0.02em;
            margin: 0;
            color: var(--text-main);
        }

        .detail-specs-table { width: 100%; border-collapse: collapse; }
        .detail-specs-table tr { border-bottom: 1px solid rgba(0,0,0,0.05); }
        .detail-specs-table tr:last-child { border-bottom: none; }
        
        .detail-specs-table td {
            padding: 16px 0;
            font-size: 15px;
            vertical-align: top;
        }

        .spec-label { color: var(--text-muted); font-weight: 600; width: 140px; }
        .spec-value { color: var(--text-main); font-weight: 500; }

        /* Reviews */
        .reviews-section {
            background: var(--surface-color);
            border-radius: var(--radius-xl);
            padding: 6px;
            box-shadow: var(--shadow-soft);
            border: 1px solid rgba(0,0,0,0.03);
            margin-top: 64px;
            grid-column: 1 / -1;
        }
        
        .reviews-inner {
            background: var(--bg-color);
            border-radius: calc(var(--radius-xl) - 6px);
            padding: 48px;
        }

        .reviews-header {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: -0.02em;
            margin-bottom: 32px;
        }

        @@media (max-width: 1024px) {
            .detail-layout { grid-template-columns: 1fr; gap: 40px; }
            .detail-image-card { position: relative; top: 0; min-height: auto; padding: 40px; }
        }
    </style>
}

<div class="container">
    <div class="main-layout">
        <main>
            <div class="detail-breadcrumb">
                <a href="/">Trang chủ</a>
                <span class="separator">/</span>
                @if (Model.Product.Category != null)
                {
                    <a href="/Home/Index?categoryId=@Model.Product.CategoryId">@Model.Product.Category.CategoryName</a>
                    <span class="separator">/</span>
                }
                <span class="current">@Model.Product.Name</span>
            </div>

            <div class="detail-layout">
                <!-- LEFT: Image (Sticky) -->
                <div>
                    <div class="detail-image-card">
                        <img src="@Model.Product.ImageUrl" alt="@Model.Product.Name" onerror="this.src='/images/Giao diện trang chủ/ảnh để chuyển slide/Ảnh 4.png'" />
                    </div>
                </div>

                <!-- RIGHT: Purchase & Specs -->
                <div class="detail-right-col">
                    <div>
                        <div class="detail-product-name">@Model.Product.Name</div>
                        <div class="detail-product-brand">
                            Thương hiệu:
                            @if (Model.Product.Category != null) { <span>@Model.Product.Category.CategoryName</span> }
                        </div>
                    </div>

                    <div class="detail-status-row">
                        <div class="detail-status-badge"><i class="bi bi-check2"></i> Còn hàng</div>
                        <div style="font-size: 13px; color: var(--text-muted); font-weight: 500;">Mã SP: SP@(Model.Product.ProductId.ToString("D4"))</div>
                    </div>

                    <div class="detail-price-section">
                        <div class="detail-price" id="displayPrice">@Model.Product.Price.ToString("N0")đ</div>
                        <div style="font-size: 14px; color: var(--text-muted); margin-bottom: 4px; font-weight: 500;">
                            <i class="bi bi-shield-check" style="color: #10b981; margin-right: 4px;"></i> Bảo hành chính hãng 12 tháng
                        </div>
                        <div style="font-size: 14px; color: var(--text-muted); font-weight: 500;">
                            <i class="bi bi-box-seam" style="color: var(--primary-color); margin-right: 4px;"></i> Còn @Model.Product.Stock sản phẩm trong kho
                        </div>
                    </div>

                    @if (Model.Variants != null && Model.Variants.Any())
                    {
                        <div class="variant-section">
                            <span class="variant-label">Chọn phiên bản</span>
                            <div class="variant-options">
                                @foreach (var variant in Model.Variants)
                                {
                                    var variantPrice = variant.Price ?? Model.Product.Price;
                                    <div class="variant-btn"
                                         data-variant-id="@variant.VariantId"
                                         data-price="@variantPrice"
                                         onclick="selectVariant(this)">
                                        <div class="variant-title">@variant.Color @variant.ROM</div>
                                        <div class="variant-price">@variantPrice.ToString("N0")đ</div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="detail-quantity-section">
                        <span class="detail-quantity-label">Số lượng</span>
                        <div class="detail-quantity-control">
                            <button type="button" onclick="changeQty(-1)"><i class="bi bi-dash"></i></button>
                            <input type="number" id="detailQty" value="1" min="1" max="99" readonly />
                            <button type="button" onclick="changeQty(1)"><i class="bi bi-plus"></i></button>
                        </div>
                    </div>

                    <div class="detail-actions">
                        <form asp-controller="Cart" asp-action="Add" method="post" style="flex: 1; display: flex; gap: 16px;" id="addToCartForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                            <input type="hidden" name="variantId" id="hiddenVariantId" value="" />
                            <input type="hidden" name="qty" id="hiddenQty" value="1" />

                            <button type="submit" class="detail-btn-buy" name="action" value="buy">
                                Mua ngay
                            </button>
                            <button type="submit" class="detail-btn-cart" name="action" value="cart" title="Thêm vào giỏ hàng">
                                <i class="bi bi-bag-plus"></i>
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Specs in Double Bezel -->
                <div class="detail-specs-card">
                    <div class="detail-specs-inner">
                        <div class="detail-specs-header">
                            <h2>Thông số kỹ thuật</h2>
                        </div>
                        <table class="detail-specs-table">
                            @if (Model.Detail != null)
                            {
                                <tr><td class="spec-label">Màn hình</td><td class="spec-value">@(Model.Detail.Screen ?? "Đang cập nhật")</td></tr>
                                <tr><td class="spec-label">CPU</td><td class="spec-value">@(Model.Detail.CPU ?? "Đang cập nhật")</td></tr>
                                <tr><td class="spec-label">RAM</td><td class="spec-value">@(Model.Detail.RAM ?? "Đang cập nhật")</td></tr>
                                <tr><td class="spec-label">Bộ nhớ</td><td class="spec-value">@(Model.Detail.ROM ?? "Đang cập nhật")</td></tr>
                                <tr><td class="spec-label">Camera</td><td class="spec-value">@(Model.Detail.Camera ?? "Đang cập nhật")</td></tr>
                                <tr><td class="spec-label">Pin</td><td class="spec-value">@(Model.Detail.Battery ?? "Đang cập nhật")</td></tr>
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" style="text-align: center; padding: 40px 0; color: var(--text-muted); font-weight: 500;">
                                        Thông số kỹ thuật đang được cập nhật
                                    </td>
                                </tr>
                            }
                        </table>
                    </div>
                </div>                <!-- Đánh giá Sản Phẩm -->
                <div class="reviews-section">
                    <div class="reviews-inner">
                        <h3 class="reviews-header">Đánh giá từ khách hàng</h3>
                        
                        @{
                            int totalReviews = Model.Reviews?.Count ?? 0;
                            double avgRating = totalReviews > 0 ? Model.Reviews.Average(r => r.Rating) : 0;
                            int count5 = Model.Reviews?.Count(r => r.Rating == 5) ?? 0;
                            int count4 = Model.Reviews?.Count(r => r.Rating == 4) ?? 0;
                            int count3 = Model.Reviews?.Count(r => r.Rating == 3) ?? 0;
                            int count2 = Model.Reviews?.Count(r => r.Rating == 2) ?? 0;
                            int count1 = Model.Reviews?.Count(r => r.Rating == 1) ?? 0;

                            double pct5 = totalReviews > 0 ? (count5 * 100.0 / totalReviews) : 0;
                            double pct4 = totalReviews > 0 ? (count4 * 100.0 / totalReviews) : 0;
                            double pct3 = totalReviews > 0 ? (count3 * 100.0 / totalReviews) : 0;
                            double pct2 = totalReviews > 0 ? (count2 * 100.0 / totalReviews) : 0;
                            double pct1 = totalReviews > 0 ? (count1 * 100.0 / totalReviews) : 0;
                        }

                        <div style="display: flex; gap: 48px; align-items: center; margin-bottom: 48px; flex-wrap: wrap;">
                            <div style="text-align: center; min-width: 140px;">
                                <div style="font-size: 64px; font-weight: 800; color: var(--text-main); letter-spacing: -0.04em; line-height: 1;">
                                    @avgRating.ToString("0.0")
                                </div>
                                <div style="color: #fbbf24; font-size: 20px; margin: 12px 0;">
                                    @for(int i=1; i<=5; i++){
                                        if(i <= Math.Round(avgRating)){
                                            <i class="bi bi-star-fill"></i>
                                        } else {
                                            <i class="bi bi-star"></i>
                                        }
                                    }
                                </div>
                                <div style="color: var(--text-muted); font-size: 14px; font-weight: 600;">@totalReviews bài đánh giá</div>
                            </div>
                            <div style="flex: 1; min-width: 280px;">
                                @{ var starCounts = new[] { new { star = 5, pct = pct5 }, new { star = 4, pct = pct4 }, new { star = 3, pct = pct3 }, new { star = 2, pct = pct2 }, new { star = 1, pct = pct1 } }; }
                                @foreach (var s in starCounts)
                                {
                                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                                        <span style="min-width: 24px; font-size: 14px; font-weight: 700; color: var(--text-main);">@s.star <i class="bi bi-star-fill" style="font-size:10px; color: #fbbf24;"></i></span>
                                        <div style="flex: 1; height: 6px; background: rgba(0,0,0,0.05); border-radius: var(--radius-pill); overflow: hidden;">
                                            <div style="height: 100%; width: @s.pct%; background: var(--text-main); border-radius: var(--radius-pill);"></div>
                                        </div>
                                        <span style="min-width: 40px; text-align: right; font-size: 13px; font-weight: 600; color: var(--text-muted);">@s.pct.ToString("0")%</span>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (Model.CanReview)
                        {
                            <div style="background: rgba(0,0,0,0.02); border-radius: var(--radius-lg); padding: 32px; margin-bottom: 40px;">
                                <h5 style="font-weight: 800; font-size: 18px; margin-bottom: 24px;">Viết đánh giá của bạn</h5>
                                <form asp-action="AddReview" asp-controller="Home" method="post">
                                    <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                                    <div style="margin-bottom: 20px;">
                                        <div class="rating-select" style="font-size: 28px; cursor: pointer; color: #fbbf24; display: inline-flex; gap: 4px;">
                                            <i class="bi bi-star-fill" data-val="1"></i>
                                            <i class="bi bi-star-fill" data-val="2"></i>
                                            <i class="bi bi-star-fill" data-val="3"></i>
                                            <i class="bi bi-star-fill" data-val="4"></i>
                                            <i class="bi bi-star-fill" data-val="5"></i>
                                        </div>
                                        <input type="hidden" name="rating" id="ratingValue" value="5" />
                                    </div>
                                    <div style="margin-bottom: 20px;">
                                        <textarea name="comment" style="width: 100%; border: 1px solid rgba(0,0,0,0.1); border-radius: var(--radius-md); padding: 16px; font-size: 15px; resize: vertical; min-height: 100px; font-family: inherit; background: var(--surface-color); outline: none;" placeholder="Cảm nhận của bạn về sản phẩm..." required></textarea>
                                    </div>
                                    <button type="submit" style="background: var(--primary-color); color: var(--surface-color); border: none; padding: 14px 32px; border-radius: var(--radius-pill); font-weight: 700; cursor: pointer; transition: all 0.3s var(--bezier-smooth);">Gửi đánh giá</button>
                                </form>
                            </div>
                        }

                        <div>
                            @if (Model.Reviews != null && Model.Reviews.Any())
                            {
                                foreach (var review in Model.Reviews)
                                {
                                    <div style="border-bottom: 1px solid rgba(0,0,0,0.05); padding: 24px 0;">
                                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                                            <div style="width: 40px; height: 40px; border-radius: 50%; background: rgba(0,0,0,0.05); display: flex; align-items: center; justify-content: center; font-weight: 700; color: var(--text-main);">
                                                @(review.User.FullName?.Substring(0,1).ToUpper() ?? "U")
                                            </div>
                                            <div>
                                                <div style="font-weight: 700; color: var(--text-main); font-size: 15px;">@review.User.FullName</div>
                                                <div style="color: #10b981; font-size: 12px; font-weight: 600;"><i class="bi bi-check2-circle"></i> Đã mua tại TechStore</div>
                                            </div>
                                        </div>
                                        <div style="color: #fbbf24; font-size: 13px; margin-bottom: 12px;">
                                            @for(int i=1; i<=5; i++){
                                                if(i <= review.Rating){ <i class="bi bi-star-fill"></i> } else { <i class="bi bi-star"></i> }
                                            }
                                        </div>
                                        <p style="color: var(--text-main); margin-bottom: 12px; line-height: 1.6; font-size: 15px;">@review.Comment</p>
                                        <div style="color: var(--text-muted); font-size: 13px; font-weight: 500;">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div style="text-align: center; color: var(--text-muted); padding: 48px 0; font-weight: 500;">Chưa có đánh giá nào cho sản phẩm này.</div>
                            }
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const firstVariant = document.querySelector('.variant-btn');
            if (firstVariant) {
                selectVariant(firstVariant);
            }

            const form = document.getElementById('addToCartForm');
            if (form) {
                form.addEventListener('submit', async function (e) {
                    e.preventDefault();
                    
                    const submitter = e.submitter;
                    const isBuy = submitter && submitter.value === 'buy';

                    const params = new URLSearchParams();
                    const inputs = form.querySelectorAll('input[name]');
                    inputs.forEach(inp => params.append(inp.name, inp.value));
                    
                    if (isBuy) {
                        params.append('isBuyNow', 'true');
                    }
                    
                    try {
                        const response = await fetch(form.action, {
                            method: 'POST',
                            body: params,
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });

                        if (response.ok) {
                            let result;
                            const contentType = response.headers.get('content-type');
                            if (contentType && contentType.includes('application/json')) {
                                result = await response.json();
                            } else {
                                result = { success: true };
                            }

                            if (result.success) {
                                if (isBuy) {
                                    window.location.href = '/Cart/Checkout';
                                } else {
                                    const badge = document.querySelector('.cart-badge');
                                    if (badge) {
                                        badge.textContent = parseInt(badge.textContent || '0') + parseInt(document.getElementById('hiddenQty').value || '1');
                                    }
                                    showToast('Đã thêm vào giỏ hàng');
                                }
                            } else {
                                alert('Có lỗi xảy ra: ' + (result.message || ''));
                            }
                        } else {
                            form.submit();
                        }
                    } catch (error) {
                        form.submit();
                    }
                });
            }
        });

        function selectVariant(element) {
            document.querySelectorAll('.variant-btn').forEach(btn => btn.classList.remove('active'));
            element.classList.add('active');

            const price = parseFloat(element.getAttribute('data-price'));
            document.getElementById('displayPrice').innerText = new Intl.NumberFormat('vi-VN').format(price) + 'đ';

            // Chỉ gửi VariantId lên server; giá và tên do server tự tra từ DB.
            document.getElementById('hiddenVariantId').value = element.getAttribute('data-variant-id');
        }

        function changeQty(delta) {
            const input = document.getElementById('detailQty');
            const hidden = document.getElementById('hiddenQty');
            let val = parseInt(input.value) || 1;
            val = Math.max(1, Math.min(99, val + delta));
            input.value = val;
            hidden.value = val;
        }

        const stars = document.querySelectorAll('.rating-select i');
        const ratingInput = document.getElementById('ratingValue');
        stars.forEach(star => {
            star.addEventListener('click', function() {
                const val = parseInt(this.getAttribute('data-val'));
                ratingInput.value = val;
                stars.forEach(s => {
                    if (parseInt(s.getAttribute('data-val')) <= val) {
                        s.classList.remove('bi-star');
                        s.classList.add('bi-star-fill');
                    } else {
                        s.classList.remove('bi-star-fill');
                        s.classList.add('bi-star');
                    }
                });
            });
        });

        function showToast(msg) {
            let toast = document.getElementById('cartToast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'cartToast';
                toast.style.cssText = 'position:fixed;top:40px;left:50%;transform:translateX(-50%) translateY(-100px);z-index:9999;background:var(--text-main);color:var(--surface-color);padding:14px 32px;border-radius:999px;font-size:14px;font-weight:700;box-shadow:0 12px 32px rgba(0,0,0,0.15);transition:transform 0.5s cubic-bezier(0.34,1.56,0.64,1);display:flex;align-items:center;gap:12px;';
                toast.innerHTML = '<i class="bi bi-check-lg" style="color:#10b981;font-size:18px;"></i> <span class="toast-msg"></span>';
                document.body.appendChild(toast);
            }
            toast.querySelector('.toast-msg').textContent = msg;
            
            requestAnimationFrame(() => {
                toast.style.transform = 'translateX(-50%) translateY(0)';
            });
            
            setTimeout(() => {
                toast.style.transform = 'translateX(-50%) translateY(-100px)';
            }, 3000);
        }
    </script>
}
