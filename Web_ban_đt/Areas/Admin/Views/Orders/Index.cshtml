@model IEnumerable<TechStoreWeb.Models.Order>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0 text-techblue">Quản lý Đơn hàng</h3>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Ngày đặt</th>
                        <th>Khách hàng</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td><span class="fw-bold">#@order.OrderId</span></td>
                            <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@order.User?.FullName</td>
                            <td class="text-danger fw-bold">@order.TotalAmount.ToString("N0") VNĐ</td>
                            <td>
                                @{
                                    var statusClass = "bg-secondary";
                                    var statusText = order.Status;
                                    
                                    switch (order.Status)
                                    {
                                        case "Pending": statusClass = "bg-warning text-dark"; statusText = "Chờ xử lý"; break;
                                        case "WaitingForPickup": statusClass = "bg-info text-dark"; statusText = "Chờ lấy hàng"; break;
                                        case "PickedUp": statusClass = "bg-primary"; statusText = "Đã lấy hàng"; break;
                                        case "Shipping": statusClass = "bg-info"; statusText = "Đang vận chuyển"; break;
                                        case "Delivered": statusClass = "bg-success"; statusText = "Đã giao"; break;
                                        case "Cancelled": statusClass = "bg-danger"; statusText = "Đã hủy"; break;
                                    }
                                }
                                <span class="badge @statusClass">@statusText</span>
                            </td>
                            <td class="text-center">
                                <a href="/Admin/Orders/Details/@order.OrderId" class="btn btn-sm btn-primary">
                                    <i class="bi bi-eye"></i> Xem/Cập nhật
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-box2-heart" style="font-size: 3rem;"></i>
                <p class="mt-3">Chưa có đơn hàng nào.</p>
            </div>
        }
    </div>
</div>
