@model List<TechStoreWeb.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
    var discount = ViewBag.Discount ?? 0m;
}

@section Styles {
    <style>
        .cart-wrapper {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto 120px auto;
        }
        
        .cart-header {
            display: flex;
            align-items: center;
            margin-bottom: 48px;
            padding-bottom: 24px;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }
        
        .cart-icon-box {
            width: 56px;
            height: 56px;
            background: var(--primary-color);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 24px;
            box-shadow: var(--shadow-soft);
            color: var(--surface-color);
            font-size: 24px;
        }
        
        .cart-title {
            font-weight: 800;
            color: var(--text-main);
            margin: 0;
            font-size: 32px;
            letter-spacing: -0.04em;
        }

        .cart-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 48px;
            align-items: start;
        }

        .cart-card {
            background: var(--surface-color);
            border-radius: var(--radius-xl);
            padding: 6px;
            box-shadow: var(--shadow-soft);
            border: 1px solid rgba(0,0,0,0.03);
        }
        
        .cart-card-inner {
            background: var(--bg-color);
            border-radius: calc(var(--radius-xl) - 6px);
            padding: 40px;
        }
        
        .table-cart { width: 100%; border-collapse: collapse; }
        
        .table-cart th {
            font-weight: 700;
            color: var(--text-muted);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            padding-bottom: 16px;
            font-size: 13px;
            text-align: left;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        
        .table-cart th.text-center, .table-cart td.text-center { text-align: center; }
        .table-cart th.text-right, .table-cart td.text-right { text-align: right; }
        
        .table-cart td {
            vertical-align: middle;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            padding: 32px 0;
            color: var(--text-main);
            font-size: 16px;
        }
        
        .table-cart tr:last-child td { border-bottom: none; padding-bottom: 0; }
        
        .product-info { display: flex; align-items: center; gap: 24px; }
        
        .product-info img {
            width: 96px; 
            height: 96px; 
            object-fit: contain; 
            border-radius: var(--radius-md); 
            background: var(--surface-color);
            padding: 12px;
            box-shadow: var(--shadow-soft);
            transition: transform 0.4s var(--bezier-smooth);
            mix-blend-mode: multiply;
        }
        
        .product-info:hover img { transform: scale(1.05) translateY(-4px); }
        
        .product-name {
            font-weight: 700;
            color: var(--text-main);
            font-size: 16px;
            line-height: 1.4;
        }

        .qty-control {
            display: inline-flex;
            align-items: center;
            border-radius: var(--radius-pill);
            background: var(--surface-color);
            padding: 4px;
            box-shadow: var(--shadow-soft);
        }
        .qty-btn {
            background: transparent;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--text-main);
            font-size: 18px;
            transition: all 0.3s var(--bezier-smooth);
        }
        .qty-btn:hover:not(:disabled) { background: rgba(0,0,0,0.04); }
        .qty-input { width: 32px; text-align: center; font-weight: 700; color: var(--text-main); }
        
        .checkout-btn {
            background: var(--primary-color);
            color: var(--surface-color);
            border: none;
            padding: 20px 24px;
            border-radius: var(--radius-pill);
            font-weight: 700;
            transition: all 0.4s var(--bezier-smooth);
            text-align: center;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 12px;
            width: 100%;
            font-size: 16px;
            cursor: pointer;
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
            text-decoration: none;
            margin-top: 32px;
        }
        .checkout-btn:hover {
            transform: translateY(-4px) scale(0.98);
            box-shadow: 0 16px 32px rgba(0,0,0,0.2);
            color: white;
            background: var(--primary-color);
        }
        
        .cart-summary-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 24px;
            color: var(--text-muted);
            font-size: 15px;
            font-weight: 600;
        }
        .cart-summary-item.total {
            color: var(--text-main);
            font-weight: 800;
            font-size: 24px;
            margin-bottom: 0;
            padding-top: 32px;
            border-top: 1px solid rgba(0,0,0,0.05);
        }
        
        .voucher-input-group {
            display: flex;
            margin: 32px 0;
            background: var(--surface-color);
            border-radius: var(--radius-pill);
            padding: 6px;
            box-shadow: var(--shadow-soft);
        }
        .voucher-input-group input {
            flex: 1;
            padding: 12px 16px 12px 24px;
            border: none;
            background: transparent;
            outline: none;
            font-family: inherit;
            font-size: 14px;
            font-weight: 500;
        }
        .voucher-input-group button {
            padding: 10px 24px;
            background: var(--primary-color);
            border: none;
            border-radius: var(--radius-pill);
            color: var(--surface-color);
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s var(--bezier-smooth);
        }
        .voucher-input-group button:hover {
            transform: scale(0.95);
        }

        .custom-checkbox { width: 24px; height: 24px; cursor: pointer; accent-color: var(--primary-color); }
        
        .btn-remove {
            background: rgba(239, 68, 68, 0.1);
            border: none;
            color: #ef4444;
            cursor: pointer;
            font-size: 16px;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s var(--bezier-bounce);
        }
        .btn-remove:hover {
            background: #ef4444;
            color: white;
            transform: scale(1.1) rotate(10deg);
        }

        .empty-cart { text-align: center; padding: 120px 0; }
        .empty-cart-icon {
            width: 160px;
            height: 160px;
            background: rgba(0,0,0,0.02);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 32px auto;
            color: rgba(0,0,0,0.1);
            font-size: 64px;
        }
        .empty-cart-title {
            font-size: 32px;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 16px;
            letter-spacing: -0.04em;
        }
        .empty-cart-desc {
            color: var(--text-muted);
            margin-bottom: 48px;
            font-size: 16px;
        }
        .btn-shopping {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 20px 40px;
            background: var(--primary-color);
            color: var(--surface-color);
            border-radius: var(--radius-pill);
            font-weight: 700;
            text-decoration: none;
            transition: all 0.4s var(--bezier-smooth);
            font-size: 16px;
        }
        .btn-shopping:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 32px rgba(0,0,0,0.15);
            background: var(--primary-color);
        }
        
        form { margin: 0; }
        
        @@media (max-width: 992px) {
            .cart-grid { grid-template-columns: 1fr; gap: 32px; }
            .table-cart td { padding: 24px 0; }
        }
    </style>
}

<div class="cart-wrapper">
    <div class="cart-header">
        <div class="cart-icon-box">
            <i class="bi bi-bag"></i>
        </div>
        <h3 class="cart-title">Giỏ hàng</h3>
    </div>

    <div class="cart-grid">
        <div class="cart-card">
            <div class="cart-card-inner">
                <table class="table-cart">
                <thead>
                    <tr>
                        <th style="width:50px"></th>
                        <th>Sản phẩm</th>
                        <th style="width:140px">Đơn giá</th>
                        <th style="width:130px" class="text-center">Số lượng</th>
                        <th style="width:140px" class="text-right">Thành tiền</th>
                        <th style="width:60px"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6">
                                <div class="empty-cart">
                                    <div class="empty-cart-icon">
                                        <i class="bi bi-bag-x"></i>
                                    </div>
                                    <div class="empty-cart-title">Giỏ hàng trống</div>
                                    <div class="empty-cart-desc">Bạn chưa thêm sản phẩm nào vào giỏ.</div>
                                    <a href="/" class="btn-shopping">Khám phá ngay</a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <form asp-controller="Cart" asp-action="ToggleSelect" method="post" style="display:flex; justify-content:center;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="selected" class="selected-input" value="@item.Selected.ToString().ToLower()" />
                                        <input type="checkbox" class="custom-checkbox" @(item.Selected? "checked":"") onchange="this.form.querySelector('.selected-input').value=this.checked; this.form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));" />
                                    </form>
                                </td>
                                <td>
                                    <div class="product-info">
                                        <img src="@item.Img" alt="@item.Name"> 
                                        <span class="product-name">@item.Name</span>
                                    </div>
                                </td>
                                <td style="font-weight: 600;">@item.Price.ToString("N0")đ</td>
                                <td class="text-center">
                                    <div class="qty-control">
                                        <form asp-controller="Cart" asp-action="UpdateQty" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="qty" value="@(item.Qty - 1)" />
                                            <button type="submit" class="qty-btn" @(item.Qty <= 1 ? "disabled" : "")><i class="bi bi-dash"></i></button>
                                        </form>
                                        <span class="qty-input">@item.Qty</span>
                                        <form asp-controller="Cart" asp-action="UpdateQty" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="qty" value="@(item.Qty + 1)" />
                                            <button type="submit" class="qty-btn"><i class="bi bi-plus"></i></button>
                                        </form>
                                    </div>
                                </td>
                                <td class="text-right" style="color: var(--primary-color); font-weight: 800;">@( (item.Price * item.Qty).ToString("N0") )đ</td>
                                <td class="text-right">
                                    <form asp-controller="Cart" asp-action="Remove" method="post" style="display:flex; justify-content:flex-end;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn-remove" title="Xóa sản phẩm"><i class="bi bi-x-lg"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
                </table>
            </div>
        </div>

        <div class="cart-card">
            <div class="cart-card-inner">
                <h6 style="font-weight: 800; color: var(--text-main); font-size: 24px; margin-bottom: 40px; margin-top: 0; letter-spacing: -0.02em;">Tóm tắt</h6>
                
                @{
                    var subtotal = Model?.Where(i=>i.Selected).Sum(i=>i.Price * i.Qty) ?? 0m;
                    var shipping = (subtotal > 0) ? 20000m : 0m;
                    var total = Math.Max(subtotal + shipping - (discount ?? 0m), 0m);
                }
                
                <div class="cart-summary-item"><span>Tạm tính</span><span style="color: var(--text-main);">@subtotal.ToString("N0")đ</span></div>
                
                @if (discount > 0)
                {
                    <div class="cart-summary-item"><span style="color: #10b981;"><i class="bi bi-tag-fill me-2"></i>Mã giảm giá</span><span style="color: #10b981;">- @discount?.ToString("N0")đ</span></div>
                }
                
                <div class="cart-summary-item"><span>Phí vận chuyển</span><span style="color: var(--text-main);">@shipping.ToString("N0")đ</span></div>
                
                <form asp-controller="Cart" asp-action="ApplyVoucher" method="post" class="voucher-input-group">
                    @Html.AntiForgeryToken()
                    <input type="text" name="code" placeholder="Nhập mã ưu đãi..." required>
                    <button type="submit">Áp dụng</button>
                </form>

                <div class="cart-summary-item total">
                    <span>Tổng cộng</span>
                    <span style="color: #ef4444; font-size: 32px;">@total.ToString("N0")đ</span>
                </div>
                
                <a href="/Cart/Checkout" class="checkout-btn">
                    Tiến hành thanh toán <i class="bi bi-arrow-right"></i>
                </a>
                
                <div style="text-align: center; margin-top: 32px;">
                    <p style="color: var(--text-muted); font-size: 13px; font-weight: 500;"><i class="bi bi-shield-check" style="color: #10b981; margin-right: 4px;"></i> Thanh toán an toàn & bảo mật</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            function bindAjaxForms() {
                const cartForms = document.querySelectorAll('.cart-grid form');
                
                cartForms.forEach(form => {
                    form.addEventListener('submit', function(e) {
                        e.preventDefault();
                        
                        const submitBtns = this.querySelectorAll('button[type="submit"]');
                        submitBtns.forEach(btn => btn.style.opacity = '0.5');
                        
                        const formData = new FormData(this);
                        
                        fetch(this.action, {
                            method: this.method,
                            body: formData
                        })
                        .then(response => response.text())
                        .then(html => {
                            const parser = new DOMParser();
                            const doc = parser.parseFromString(html, 'text/html');
                            const newCartGrid = doc.querySelector('.cart-grid');
                            
                            if (newCartGrid) {
                                document.querySelector('.cart-grid').innerHTML = newCartGrid.innerHTML;
                                bindAjaxForms(); 
                                
                                const newBadge = doc.querySelector('.cart-badge');
                                const currentBadge = document.querySelector('.cart-badge');
                                if (newBadge && currentBadge) {
                                    currentBadge.textContent = newBadge.textContent;
                                }
                            } else {
                                window.location.reload();
                            }
                        })
                        .catch(err => {
                            console.error(err);
                            window.location.reload();
                        });
                    });
                });
            }
            
            bindAjaxForms();
        });
    </script>
}
