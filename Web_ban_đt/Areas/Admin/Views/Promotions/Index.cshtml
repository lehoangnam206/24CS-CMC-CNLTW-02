@model IEnumerable<TechStoreWeb.Models.Promotion>

@{
    ViewData["Title"] = "Quản lý Khuyến mại";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@ViewData["Title"]</h2>
    <a href="/Admin/Promotions/Create" class="btn btn-primary bg-techblue border-0">
        <i class="bi bi-plus-circle me-1"></i> Thêm khuyến mại mới
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Tên chương trình</th>
                    <th>Mức giảm</th>
                    <th>Thời gian áp dụng</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Name</td>
                            <td><span class="badge bg-danger">@item.DiscountPercentage%</span></td>
                            <td>
                                <small>Từ: @item.StartDate.ToString("dd/MM/yyyy HH:mm")</small><br />
                                <small>Đến: @item.EndDate.ToString("dd/MM/yyyy HH:mm")</small>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Kích hoạt</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Chưa áp dụng</span>
                                }
                            </td>
                            <td class="text-end">
                                <a href="/Admin/Promotions/Edit/@item.Id" class="btn btn-sm btn-primary" title="Sửa">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                @if (item.IsActive)
                                {
                                    <form action="/Admin/Promotions/EndPromotion/@item.Id" method="post" class="d-inline-block" onsubmit="return confirm('Bạn có chắc chắn muốn kết thúc chương trình này và khôi phục giá gốc cho tất cả sản phẩm?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Kết thúc chương trình">
                                            <i class="bi bi-stop-circle"></i> Kết thúc
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">
                            Chưa có chương trình khuyến mại nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
